@page
@using SeminaPro.Pages.Seminaires
@model SeminairesModel
@{
    ViewData["Title"] = "Séminaires";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">

<div class="page">

    <!-- HEADER -->
    <div class="header">
        <div class="badge">
            <i class="bi bi-mortarboard"></i> Formations professionnelles
        </div>

        <h1>🎓 Séminaires disponibles</h1>
        <p>Explorez, apprenez et évoluez avec les meilleurs experts</p>
    </div>

    <!-- FILTER -->
    <div class="filter">
        <form method="get">
            <input type="text" name="searchTitle" value="@Model.SearchTitle" placeholder="Rechercher..." />
            <input type="number" name="minPrice" value="@Model.MinPrice" placeholder="Prix min" />
            <input type="number" name="maxPrice" value="@Model.MaxPrice" placeholder="Prix max" />

            <button type="submit">
                <i class="bi bi-search"></i>
            </button>
        </form>
    </div>

    @if (Model.Seminaires?.Count > 0)
    {
        <div class="count">@Model.Seminaires.Count séminaire(s) disponible(s)</div>

        <div class="grid">

            @foreach (var s in Model.Seminaires)
            {
                var filled = s.Inscriptions?.Count ?? 0;
                var pct = s.NombreMaximal > 0 ? ((double)filled * 100 / s.NombreMaximal) : 0;
                var isFull = filled >= s.NombreMaximal;
                var isLogged = !string.IsNullOrEmpty(HttpContext.Session.GetString("UserEmail"));

                <div class="card">

                    <!-- IMAGE -->
                    <div class="img">
                        <img src="@(string.IsNullOrEmpty(s.ImageUrl)
                                                                                         ? "/images/default-seminaire.jpg"
                                                                                         : s.ImageUrl)"
                             onerror="this.src='/images/default-seminaire.jpg'" />

                        <span class="price">@s.Tarif.ToString("C")</span>
                    </div>

                    <!-- TOP -->
                    <div class="top">
                        <span class="code">@s.Code</span>
                        <h3>@s.Titre</h3>
                    </div>

                    <!-- BODY -->
                    <div class="body">

                        <div class="info">
                            <i class="bi bi-geo-alt"></i> @s.Lieu
                        </div>

                        <div class="info">
                            <i class="bi bi-calendar"></i> @s.DateSeminaire.ToString("dd MMM yyyy")
                        </div>

                        <div class="sem-progress">

                            <div class="progress-head">
                                <span>@filled / @s.NombreMaximal participants</span>

                                @if (isFull)
                                {
                                    <span class="tag full">Complet</span>
                                }
                                else
                                {
                                    <span class="tag open">Disponible</span>
                                }
                            </div>

                            <div class="bar">
                                <div class="fill @(isFull ? "red" : "")" style="width:@pct%"></div>
                            </div>

                        </div>

                    </div>

                    <!-- FOOTER -->
                    <div class="footer">

                        <a class="btn" asp-page="Details" asp-route-id="@s.Id">Détails</a>

                        @if (isFull)
                        {
                            <button class="btn disabled">Complet</button>
                        }
                        else if (isLogged)
                        {
                            <a class="btn success" asp-page="Inscription" asp-route-id="@s.Id">S'inscrire</a>
                        }
                        else
                        {
                            <a class="btn muted" href="/Account/Login">Connexion</a>
                        }

                    </div>

                </div>
            }

        </div>
    }
    else
    {
        <div class="empty">Aucun séminaire disponible</div>
    }

</div>

<style>

    /* PAGE */
    .page {
        max-width: 1200px;
        margin: auto;
        padding: 40px 20px;
        font-family: Segoe UI;
        background: #f5f7ff;
    }

    /* HEADER */
    .header {
        text-align: center;
        margin-bottom: 25px;
    }

    .badge {
        background: #e0e7ff;
        color: #4f46e5;
        padding: 6px 14px;
        border-radius: 20px;
        font-size: 12px;
    }

    .header h1 {
        font-size: 30px;
        font-weight: 800;
        color: #1e1b4b;
    }

    .header p {
        color: #64748b;
    }

    /* FILTER */
    .filter {
        background: white;
        padding: 15px;
        border-radius: 12px;
        margin-bottom: 20px;
    }

        .filter form {
            display: grid;
            grid-template-columns: 2fr 1fr 1fr auto;
            gap: 10px;
        }

        .filter input {
            padding: 10px;
            border: 1px solid #ddd;
            border-radius: 8px;
        }

        .filter button {
            background: #6366f1;
            color: white;
            border: none;
            border-radius: 8px;
        }

    /* GRID */
    .grid {
        display: grid;
        grid-template-columns: repeat(auto-fit,minmax(300px,1fr));
        gap: 18px;
    }

    /* CARD */
    .card {
        background: white;
        border-radius: 15px;
        overflow: hidden;
        box-shadow: 0 10px 25px rgba(0,0,0,0.08);
        transition: 0.3s;
    }

        .card:hover {
            transform: translateY(-6px);
        }

    /* IMAGE */
    .img {
        position: relative;
        height: 160px;
    }

        .img img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: 0.3s;
        }

    .card:hover .img img {
        transform: scale(1.05);
    }

    .price {
        position: absolute;
        top: 10px;
        right: 10px;
        background: #6366f1;
        color: white;
        padding: 5px 10px;
        border-radius: 10px;
        font-size: 12px;
    }

    /* TOP */
    .top {
        padding: 12px;
    }

    .code {
        font-size: 11px;
        color: gray;
    }

    /* BODY */
    .body {
        padding: 12px;
    }

    .info {
        color: #64748b;
        font-size: 13px;
        margin-bottom: 4px;
    }

    /* PROGRESS */
    .sem-progress {
        margin-top: 10px;
    }

    .progress-head {
        display: flex;
        justify-content: space-between;
        font-size: 12px;
    }

    .tag {
        font-size: 11px;
        padding: 2px 8px;
        border-radius: 20px;
    }

    .open {
        background: #dcfce7;
        color: #166534;
    }

    .full {
        background: #fee2e2;
        color: #991b1b;
    }

    .bar {
        height: 5px;
        background: #eee;
        border-radius: 10px;
    }

    .fill {
        height: 100%;
        background: #6366f1;
    }

        .fill.red {
            background: #ef4444;
        }

    /* FOOTER */
    .footer {
        display: flex;
        justify-content: space-between;
        padding: 12px;
    }

    .btn {
        padding: 6px 10px;
        border-radius: 8px;
        text-decoration: none;
        border: 1px solid #ddd;
        font-size: 12px;
    }

    .success {
        background: #10b981;
        color: white;
        border: none;
    }

    .muted {
        background: #f1f5f9;
    }

    .disabled {
        opacity: 0.5;
    }

    /* EMPTY */
    .empty {
        text-align: center;
        padding: 50px;
        color: gray;
    }

</style>