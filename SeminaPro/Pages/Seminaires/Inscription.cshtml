@page "{id}"
@model SeminaPro.Pages.Seminaires.InscriptionModel
@{
    ViewData["Title"] = "S'inscrire";
}

<div class="container py-4">
    @if (Model.Seminaire != null)
    {
        <div class="row justify-content-center">
            <div class="col-md-8">
                <div class="card shadow">
                    <div class="card-header bg-success text-white">
                        <h4 class="mb-0"><i class="bi bi-check-circle"></i> Inscription au Séminaire</h4>
                    </div>
                    <div class="card-body p-5">
                        <h5 class="card-title">@Model.Seminaire.Titre</h5>
                        <p class="card-text">
                            <strong>Date :</strong> @Model.Seminaire.DateSeminaire.ToString("dd/MM/yyyy HH:mm")<br>
                            <strong>Lieu :</strong> @Model.Seminaire.Lieu<br>
                            <strong>Tarif :</strong> @Model.Seminaire.Tarif.ToString("C")
                        </p>

                        <form method="post">
                            <div class="mb-3">
                                <label for="confirmCheckbox" class="form-label">
                                    <input type="checkbox" id="confirmCheckbox" name="confirm" required>
                                    Je confirme mon inscription à ce séminaire
                                </label>
                            </div>

                            <div class="d-flex gap-2">
                                <button type="submit" class="btn btn-success">
                                    <i class="bi bi-check-circle"></i> Confirmer l'inscription
                                </button>
                                <a href="/Seminaires/Index" class="btn btn-secondary">
                                    <i class="bi bi-arrow-left"></i> Retour
                                </a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-danger">
            Séminaire non trouvé
        </div>
    }
</div>
