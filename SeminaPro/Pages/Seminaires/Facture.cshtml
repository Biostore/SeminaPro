@page "{id:int}"
@model SeminaPro.Pages.Seminaires.FactureModel

@{
    ViewData["Title"] = "Facture d'Inscription";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<style>
    :root {
        --primary: #0f6bff;
        --dark: #0f172a;
        --light: #f8fafc;
        --border: #e2e8f0;
        --muted: #64748b;
        --success: #22c55e;
    }

    body {
        font-family: 'Segoe UI', sans-serif;
        background: var(--light);
        margin: 0;
        padding: 30px 10px;
    }

    /* CONTAINER */
    .facture {
        max-width: 900px;
        margin: auto;
        background: white;
        border-radius: 14px;
        overflow: hidden;
        box-shadow: 0 10px 30px rgba(0,0,0,0.08);
    }

    /* HEADER */
    .facture-header {
        background: linear-gradient(135deg, var(--dark), #1e293b);
        color: white;
        padding: 25px;
        display: flex;
        justify-content: space-between;
        flex-wrap: wrap;
    }

        .facture-header h2 {
            margin: 0;
            font-size: 24px;
            font-weight: 700;
        }

    .badge-status {
        margin-top: 10px;
        display: inline-block;
        background: rgba(34,197,94,0.15);
        color: var(--success);
        padding: 5px 10px;
        border-radius: 8px;
        font-size: 13px;
    }

    /* BODY */
    .facture-body {
        padding: 25px;
    }

    /* SECTION */
    .section {
        margin-bottom: 25px;
    }

    .section-title {
        font-size: 12px;
        font-weight: 700;
        color: var(--muted);
        text-transform: uppercase;
        margin-bottom: 12px;
        letter-spacing: 0.5px;
    }

    /* GRID */
    .grid-2 {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
    }

    /* FIELD */
    .field {
        margin-bottom: 12px;
    }

    .label {
        font-size: 12px;
        color: var(--muted);
        text-transform: uppercase;
    }

    .value {
        font-size: 15px;
        font-weight: 600;
        color: var(--dark);
    }

    /* SEMINAIRE CARD */
    .seminaire {
        display: flex;
        gap: 15px;
        background: var(--light);
        padding: 15px;
        border-radius: 12px;
        border: 1px solid var(--border);
    }

        .seminaire img {
            width: 120px;
            height: 120px;
            border-radius: 10px;
            object-fit: cover;
        }

    /* TABLE */
    table {
        width: 100%;
        border-collapse: collapse;
        margin-top: 10px;
    }

    th {
        text-align: left;
        font-size: 12px;
        color: var(--muted);
        padding: 10px;
        background: var(--light);
    }

    td {
        padding: 12px;
        border-bottom: 1px solid var(--border);
    }

    .amount {
        text-align: right;
        font-weight: bold;
        color: var(--primary);
    }

    /* TOTAL */
    .total-box {
        margin-top: 20px;
        display: flex;
        justify-content: flex-end;
    }

    .total {
        width: 300px;
    }

    .total-line {
        display: flex;
        justify-content: space-between;
        padding: 8px 0;
        border-bottom: 1px solid var(--border);
    }

    .total-final {
        font-size: 18px;
        font-weight: 800;
        color: var(--primary);
    }

    /* BUTTONS */
    .actions {
        display: flex;
        gap: 10px;
        justify-content: center;
        margin-top: 25px;
    }

    .btn {
        padding: 10px 18px;
        border-radius: 10px;
        border: none;
        cursor: pointer;
        font-weight: 600;
        text-decoration: none;
    }

    .btn-primary {
        background: var(--primary);
        color: white;
    }

    .btn-secondary {
        background: white;
        border: 1px solid var(--border);
        color: var(--dark);
    }

    /* HOVER */
    .btn:hover {
        transform: translateY(-2px);
        transition: 0.2s;
    }

    /* PRINT */
    @@media print {
        .actions {
            display: none;
        }

        body {
            background: white;
        }

        .facture {
            box-shadow: none;
        }
    }

    /* MOBILE */
    @@media (max-width: 768px) {
        .grid-2 {
            grid-template-columns: 1fr;
        }

        .seminaire {
            flex-direction: column;
            align-items: center;
            text-align: center;
        }
    }
</style>

<div class="facture">

    <!-- HEADER -->
    <div class="facture-header">
        <div>
            <h2>SeminaPro</h2>
            <small>Plateforme de Séminaires</small>
        </div>

        <div>
            <div>Facture #@(Model.Inscription?.Id.ToString("D6"))</div>
            <div class="badge-status">
                <i class="bi bi-check-circle"></i> Confirmée
            </div>
        </div>
    </div>

    <div class="facture-body">

        <!-- INFOS -->
        <div class="section">
            <div class="section-title">Informations</div>

            <div class="grid-2">

                <div>
                    <div class="field">
                        <div class="label">Participant</div>
                        <div class="value">@Model.Participant?.Prenom @Model.Participant?.Nom</div>
                    </div>

                    <div class="field">
                        <div class="label">Email</div>
                        <div class="value">@Model.Participant?.Email</div>
                    </div>
                </div>

                <div>
                    <div class="field">
                        <div class="label">Date</div>
                        <div class="value">@Model.Inscription?.DateInscription.ToString("dd/MM/yyyy")</div>
                    </div>

                    <div class="field">
                        <div class="label">ID Inscription</div>
                        <div class="value">#INS-@(Model.Inscription?.Id.ToString("D6"))</div>
                    </div>
                </div>

            </div>
        </div>

        <!-- SEMINAIRE -->
        <div class="section">
            <div class="section-title">Séminaire</div>

            <div class="seminaire">
                <img src="@(Model.Seminaire?.ImageUrl ?? "/images/default.png")" />

                <div>
                    <h3>@Model.Seminaire?.Titre</h3>
                    <p>@Model.Seminaire?.Lieu</p>
                    <p>@Model.Seminaire?.DateSeminaire.ToString("dd MMM yyyy")</p>
                </div>
            </div>
        </div>

        <!-- TABLE -->
        <div class="section">
            <div class="section-title">Détail</div>

            <table>
                <thead>
                    <tr>
                        <th>Description</th>
                        <th>Prix</th>
                        <th>Qté</th>
                        <th>Total</th>
                    </tr>
                </thead>

                <tbody>
                    <tr>
                        <td>@Model.Seminaire?.Titre</td>
                        <td>@Model.Seminaire?.Tarif DH</td>
                        <td>1</td>
                        <td class="amount">@Model.Seminaire?.Tarif DH</td>
                    </tr>
                </tbody>
            </table>

            <div class="total-box">
                <div class="total">
                    <div class="total-line">
                        <span>Total</span>
                        <span>@Model.Seminaire?.Tarif DH</span>
                    </div>

                    <div class="total-line total-final">
                        <span>TTC</span>
                        <span>@Model.Seminaire?.Tarif DH</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- ACTIONS -->
        <div class="actions">
            <button class="btn btn-primary" onclick="window.print()">
                <i class="bi bi-download"></i> PDF
            </button>

            <a href="javascript:history.back()" class="btn btn-secondary">
                Retour
            </a>
        </div>

    </div>
</div>