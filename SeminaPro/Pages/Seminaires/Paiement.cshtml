@page "{id}"
@model SeminaPro.Pages.Seminaires.PaiementModel

@{
    ViewData["Title"] = "Paiement de l'inscription";
}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
<script src="https://js.stripe.com/v3/"></script>

<style>
    :root {
        --primary: #0f6bff;
        --success: #22c55e;
        --danger: #ef4444;
        --dark: #1e293b;
        --light: #f1f5f9;
        --muted: #64748b;
        --border: #e2e8f0;
    }

    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        font-family: 'Inter', sans-serif;
        background: linear-gradient(135deg, var(--light) 0%, #e0f2ff 100%);
        min-height: 100vh;
        padding: 2rem 0;
    }

    /* ===== STEPPER ===== */
    .stepper {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        margin-bottom: 2.5rem;
        justify-content: center;
    }

    .stepper-item {
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .stepper-number {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        transition: all 0.3s ease;
        border: 2px solid var(--border);
        background: white;
        color: var(--muted);
    }

    .stepper-item.active .stepper-number {
        background: var(--primary);
        color: white;
        border-color: var(--primary);
        transform: scale(1.1);
        box-shadow: 0 0 0 8px rgba(15, 107, 255, 0.1);
    }

    .stepper-item.completed .stepper-number {
        background: var(--success);
        color: white;
        border-color: var(--success);
    }

    .stepper-label {
        font-size: 0.85rem;
        font-weight: 600;
        color: var(--muted);
        text-align: center;
        min-width: 80px;
    }

    .stepper-item.active .stepper-label {
        color: var(--primary);
    }

    .stepper-item.completed .stepper-label {
        color: var(--success);
    }

    .stepper-line {
        height: 2px;
        flex: 1;
        background: var(--border);
        margin: 0 0.5rem;
        transition: background 0.3s ease;
    }

    .stepper-line.active {
        background: var(--primary);
    }

    /* ===== LOADING ANIMATION ===== */
    .loading-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0, 0, 0, 0.5);
        display: none;
        align-items: center;
        justify-content: center;
        z-index: 9999;
    }

    .loading-overlay.active {
        display: flex;
    }

    .loading-spinner {
        background: white;
        border-radius: 16px;
        padding: 3rem;
        text-align: center;
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.2);
    }

    .spinner {
        width: 60px;
        height: 60px;
        border: 4px solid var(--border);
        border-top-color: var(--primary);
        border-right-color: var(--primary);
        border-radius: 50%;
        animation: spin 1s linear infinite;
        margin: 0 auto 1rem;
    }

    @@keyframes spin {
        to { transform: rotate(360deg); }
    }

    .loading-text {
        color: var(--dark);
        font-weight: 600;
        margin: 0.5rem 0;
    }

    .loading-subtext {
        color: var(--muted);
        font-size: 0.9rem;
    }

    /* ===== VALIDATION MESSAGES ===== */
    .validation-error {
        color: var(--danger);
        font-size: 0.8rem;
        margin-top: 0.3rem;
        display: none;
    }

    .form-group.error input {
        border-color: var(--danger);
    }

    .form-group.error .validation-error {
        display: block;
    }

    .form-group.success input {
        border-color: var(--success);
    }

    .paiement-wrapper {
        max-width: 1000px;
        margin: 0 auto;
    }

    .paiement-container {
        display: grid;
        grid-template-columns: 1fr 350px;
        gap: 2rem;
        margin-bottom: 2rem;
    }

    .paiement-form {
        background: white;
        border-radius: 16px;
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.08);
        padding: 2.5rem;
    }

    .paiement-summary {
        background: white;
        border-radius: 16px;
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.08);
        padding: 2rem;
        height: fit-content;
        position: sticky;
        top: 2rem;
    }

    .form-title {
        font-size: 1.8rem;
        font-weight: 700;
        color: var(--dark);
        margin-bottom: 0.5rem;
    }

    .form-subtitle {
        color: var(--muted);
        margin-bottom: 2rem;
        font-size: 0.95rem;
    }

    .form-section {
        margin-bottom: 2.5rem;
    }

    .section-title {
        font-size: 1rem;
        font-weight: 600;
        color: var(--dark);
        margin-bottom: 1.5rem;
        padding-bottom: 1rem;
        border-bottom: 2px solid var(--border);
    }

    .payment-methods {
        display: grid;
        gap: 1rem;
    }

    .payment-option {
        position: relative;
        cursor: pointer;
    }

    .payment-option input[type="radio"] {
        position: absolute;
        opacity: 0;
        cursor: pointer;
    }

    .payment-label {
        display: flex;
        align-items: center;
        gap: 1rem;
        padding: 1.25rem;
        border: 2px solid var(--border);
        border-radius: 12px;
        transition: all 0.3s ease;
        cursor: pointer;
        background: var(--light);
    }

    .payment-option input[type="radio"]:checked + .payment-label {
        border-color: var(--primary);
        background: rgba(15, 107, 255, 0.05);
    }

    .payment-icon {
        width: 48px;
        height: 48px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: var(--light);
        border-radius: 8px;
        font-size: 1.5rem;
    }

    .payment-info h4 {
        color: var(--dark);
        margin-bottom: 0.25rem;
    }

    .payment-info p {
        color: var(--muted);
        font-size: 0.85rem;
    }

    .form-group {
        margin-bottom: 1.5rem;
    }

    .form-group label {
        display: block;
        margin-bottom: 0.5rem;
        color: var(--dark);
        font-weight: 500;
        font-size: 0.9rem;
    }

    .form-group input,
    .form-group select {
        width: 100%;
        padding: 0.875rem;
        border: 2px solid var(--border);
        border-radius: 8px;
        font-size: 0.95rem;
        transition: all 0.3s ease;
        font-family: inherit;
    }

    .form-group input:focus,
    .form-group select:focus {
        outline: none;
        border-color: var(--primary);
        box-shadow: 0 0 0 3px rgba(15, 107, 255, 0.1);
    }

    .form-row {
        display: grid;
        grid-template-columns: 2fr 1fr;
        gap: 1rem;
    }

    .summary-section {
        margin-bottom: 1.5rem;
    }

    .summary-title {
        font-size: 0.85rem;
        font-weight: 600;
        text-transform: uppercase;
        color: var(--muted);
        margin-bottom: 1rem;
    }

    .seminaire-info {
        background: var(--light);
        padding: 1rem;
        border-radius: 8px;
        margin-bottom: 1rem;
    }

    .seminaire-title {
        font-weight: 600;
        color: var(--dark);
        margin-bottom: 0.5rem;
        font-size: 0.95rem;
    }

    .seminaire-detail {
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-size: 0.85rem;
        color: var(--muted);
        margin: 0.3rem 0;
    }

    .pricing-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0.75rem 0;
        border-bottom: 1px solid var(--border);
    }

    .pricing-row:last-child {
        border-bottom: none;
    }

    .pricing-label {
        color: var(--muted);
        font-size: 0.9rem;
    }

    .pricing-value {
        color: var(--dark);
        font-weight: 500;
    }

    .total-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 1.25rem 0;
        border-top: 2px solid var(--border);
        margin-top: 1.25rem;
    }

    .total-label {
        font-weight: 600;
        color: var(--dark);
        font-size: 1rem;
    }

    .total-amount {
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--primary);
    }

    .btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        padding: 1rem 1.5rem;
        border: none;
        border-radius: 8px;
        font-weight: 600;
        font-size: 0.95rem;
        cursor: pointer;
        transition: all 0.3s ease;
        text-decoration: none;
    }

    .btn-primary {
        background: var(--primary);
        color: white;
        width: 100%;
    }

    .btn-primary:hover {
        background: #0a54d4;
        box-shadow: 0 4px 12px rgba(15, 107, 255, 0.3);
    }

    .btn-secondary {
        background: var(--light);
        color: var(--dark);
        margin-top: 0.75rem;
        width: 100%;
    }

    .btn-secondary:hover {
        background: var(--border);
    }

    .checkbox-group {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        margin-top: 1.5rem;
        padding: 1rem;
        background: var(--light);
        border-radius: 8px;
    }

    .checkbox-group input[type="checkbox"] {
        width: 18px;
        height: 18px;
        cursor: pointer;
        accent-color: var(--primary);
    }

    .checkbox-group label {
        margin: 0;
        cursor: pointer;
        font-size: 0.9rem;
        color: var(--muted);
    }

    .alert {
        padding: 1rem;
        border-radius: 8px;
        margin-bottom: 1.5rem;
    }

    .alert-danger {
        background: #fee2e2;
        color: #991b1b;
        border-left: 4px solid var(--danger);
    }

    .alert-success {
        background: #dcfce7;
        color: #166534;
        border-left: 4px solid var(--success);
    }
</style>

<div class="paiement-wrapper">
    <!-- Messages -->
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">
            <i class="bi bi-exclamation-circle"></i>
            @TempData["Error"]
        </div>
    }

    <!-- STEPPER -->
    <div class="stepper">
        <div class="stepper-item active" id="step1">
            <div class="stepper-number">1</div>
            <div class="stepper-label">Méthode</div>
        </div>
        <div class="stepper-line"></div>
        <div class="stepper-item" id="step2">
            <div class="stepper-number">2</div>
            <div class="stepper-label">Informations</div>
        </div>
        <div class="stepper-line"></div>
        <div class="stepper-item" id="step3">
            <div class="stepper-number">3</div>
            <div class="stepper-label">Confirmation</div>
        </div>
    </div>

    <!-- LOADING OVERLAY -->
    <div class="loading-overlay" id="loadingOverlay">
        <div class="loading-spinner">
            <div class="spinner"></div>
            <div class="loading-text">Traitement du paiement...</div>
            <div class="loading-subtext" id="loadingSubtext">Veuillez patienter</div>
        </div>
    </div>

    <form method="post" class="paiement-container" id="paymentForm">

        <!-- Formulaire de Paiement -->
        <div class="paiement-form">

            <h1 class="form-title">Paiement de l'Inscription</h1>
            <p class="form-subtitle">Choisissez votre méthode de paiement préférée</p>

            <!-- Sélection du Mode de Paiement -->
            <div class="form-section">
                <h3 class="section-title">Méthode de Paiement</h3>

                <div class="payment-methods">
                    <!-- Carte Bancaire -->
                    <div class="payment-option">
                        <input type="radio" id="card" name="selectedPaymentMethod" value="card" checked />
                        <label for="card" class="payment-label">
                            <div class="payment-icon">
                                <i class="bi bi-credit-card"></i>
                            </div>
                            <div class="payment-info">
                                <h4>Carte Bancaire</h4>
                                <p>Visa, Mastercard, American Express</p>
                            </div>
                        </label>
                    </div>

                    <!-- PayPal -->
                    <div class="payment-option">
                        <input type="radio" id="paypal" name="selectedPaymentMethod" value="paypal" />
                        <label for="paypal" class="payment-label">
                            <div class="payment-icon">
                                <i class="bi bi-wallet2"></i>
                            </div>
                            <div class="payment-info">
                                <h4>PayPal</h4>
                                <p>Paiement sécurisé via PayPal</p>
                            </div>
                        </label>
                    </div>

                    <!-- Virement -->
                    <div class="payment-option">
                        <input type="radio" id="transfer" name="selectedPaymentMethod" value="transfer" />
                        <label for="transfer" class="payment-label">
                            <div class="payment-icon">
                                <i class="bi bi-bank"></i>
                            </div>
                            <div class="payment-info">
                                <h4>Virement Bancaire</h4>
                                <p>Virement SEPA en 1-2 jours</p>
                            </div>
                        </label>
                    </div>
                </div>
            </div>

            <!-- Détails Carte Stripe -->
            <div class="form-section" id="cardDetails">
                <h3 class="section-title">Détails de la Carte</h3>

                <div class="form-group">
                    <label for="cardName">Nom sur la Carte</label>
                    <input type="text" id="cardName" name="cardName" placeholder="Jean Dupont" data-validate="required|minLength:3">
                    <span class="validation-error" id="cardName-error"></span>
                </div>

                <div class="form-group" id="card-element-group">
                    <label>Numéro de Carte</label>
                    <div id="card-element"></div>
                    <span class="validation-error" id="card-error"></span>
                </div>

                <div class="form-row">
                    <div class="form-group" id="expiry-element-group">
                        <label>Date d'Expiration</label>
                        <div id="expiry-element"></div>
                        <span class="validation-error" id="expiry-error"></span>
                    </div>
                    <div class="form-group" id="cvc-element-group">
                        <label>CVV</label>
                        <div id="cvc-element"></div>
                        <span class="validation-error" id="cvc-error"></span>
                    </div>
                </div>
            </div>

            <!-- Conditions d'Utilisation -->
            <div class="checkbox-group">
                <input type="checkbox" id="terms" name="terms" required>
                <label for="terms">
                    J'accepte les <a href="#">conditions d'utilisation</a> et la 
                    <a href="#">politique de confidentialité</a>
                </label>
            </div>

            <!-- Boutons -->
            <button type="submit" class="btn btn-primary" id="submitBtn">
                <i class="bi bi-lock"></i>
                Procéder au Paiement
            </button>
            <a href="/Seminaires/Index" class="btn btn-secondary">
                <i class="bi bi-arrow-left"></i>
                Annuler
            </a>

        </div>

        <!-- Résumé -->
        <div class="paiement-summary">

            <div class="summary-section">
                <h3 class="summary-title">Résumé de la Commande</h3>

                @if (Model.Seminaire != null)
                {
                    <div class="seminaire-info">
                        <div class="seminaire-title">
                            @Model.Seminaire.Titre
                        </div>
                        <div class="seminaire-detail">
                            <span><i class="bi bi-calendar-event"></i> Date</span>
                            <strong>@Model.Seminaire.DateSeminaire.ToString("dd/MM/yyyy")</strong>
                        </div>
                        <div class="seminaire-detail">
                            <span><i class="bi bi-geo-alt"></i> Lieu</span>
                            <strong>@Model.Seminaire.Lieu</strong>
                        </div>
                        <div class="seminaire-detail">
                            <span><i class="bi bi-clock"></i> Heure</span>
                            <strong>@Model.Seminaire.DateSeminaire.ToString("HH:mm")</strong>
                        </div>
                    </div>
                }
            </div>

            <div class="summary-section">
                <div class="pricing-row">
                    <span class="pricing-label">Frais d'inscription</span>
                    <span class="pricing-value">@(Model.Seminaire?.Tarif.ToString("N2") ?? "0,00") €</span>
                </div>
                <div class="pricing-row">
                    <span class="pricing-label">Frais de traitement</span>
                    <span class="pricing-value">0,00 €</span>
                </div>
                <div class="pricing-row">
                    <span class="pricing-label">TVA</span>
                    <span class="pricing-value">0,00 €</span>
                </div>
            </div>

            <div class="total-row">
                <span class="total-label">Total</span>
                <span class="total-amount">@(Model.Seminaire?.Tarif.ToString("N2") ?? "0,00") €</span>
            </div>

            <!-- Sécurité -->
            <div style="margin-top: 1.5rem; padding-top: 1.5rem; border-top: 1px solid var(--border); text-align: center; color: var(--muted); font-size: 0.85rem;">
                <p>
                    <i class="bi bi-shield-lock"></i>
                    Paiement 100% sécurisé
                </p>
                <p style="margin-top: 0.5rem;">
                    Vos données sont chiffrées et protégées
                </p>
            </div>

        </div>

        <input name="__RequestVerificationToken" type="hidden" value="@(Model?.RequestToken ?? "")" />
        <input type="hidden" name="stripeToken" id="stripeToken" />

    </form>
</div>

<script>
    // Initialiser Stripe
    let stripe = null;
    let elements = null;
    let cardElement = null;
    let expiryElement = null;
    let cvcElement = null;
    let currentStep = 1;
    let isProcessingPayment = false;

    // Configuration Stripe (récupérée du serveur)
    const STRIPE_PUBLIC_KEY = '@(Model?.StripePublicKey ?? "pk_test_YOUR_KEY")';

    // Initialiser Stripe au chargement
    document.addEventListener('DOMContentLoaded', function() {
        if (STRIPE_PUBLIC_KEY && STRIPE_PUBLIC_KEY !== 'pk_test_YOUR_KEY') {
            stripe = Stripe(STRIPE_PUBLIC_KEY);
            elements = stripe.elements();

            // Créer les éléments Stripe
            cardElement = elements.create('cardNumber');
            expiryElement = elements.create('cardExpiry');
            cvcElement = elements.create('cardCvc');

            // Monter les éléments
            cardElement.mount('#card-element');
            expiryElement.mount('#expiry-element');
            cvcElement.mount('#cvc-element');

            // Écouter les erreurs Stripe
            cardElement.on('change', handleStripeError);
            expiryElement.on('change', handleStripeError);
            cvcElement.on('change', handleStripeError);
        }

        // Initialiser les écouteurs d'événements
        initializeEventListeners();
        updateCardDetailsVisibility();
    });

    // Gestion de la visibilité des détails de la carte
    function updateCardDetailsVisibility() {
        const cardDetails = document.getElementById('cardDetails');
        const isCardSelected = document.getElementById('card').checked;

        if (isCardSelected) {
            cardDetails.style.display = 'block';
        } else {
            cardDetails.style.display = 'none';
        }
    }

    // Initialiser les écouteurs d'événements
    function initializeEventListeners() {
        // Changement de méthode de paiement
        document.querySelectorAll('input[name="selectedPaymentMethod"]').forEach(radio => {
            radio.addEventListener('change', function() {
                updateCardDetailsVisibility();
                updateStepper(1);
            });
        });

        // Validation du nom sur la carte
        document.getElementById('cardName')?.addEventListener('input', function(e) {
            validateField(this);
        });

        // Soumission du formulaire
        const form = document.getElementById('paymentForm');
        if (form) {
            form.addEventListener('submit', handleFormSubmit);
        }
    }

    // Gestion des erreurs Stripe
    function handleStripeError(event) {
        const errorElement = document.getElementById('card-error');

        if (event.error) {
            showFieldError('card-element-group', event.error.message);
        } else {
            hideFieldError('card-element-group');
        }
    }

    // Valider un champ
    function validateField(field) {
        const value = field.value.trim();
        const minLength = parseInt(field.getAttribute('data-minLength') || 0);
        const fieldGroup = field.closest('.form-group');

        if (!fieldGroup) return true;

        if (value.length === 0) {
            showFieldError(fieldGroup, 'Ce champ est requis');
            return false;
        }

        if (minLength > 0 && value.length < minLength) {
            showFieldError(fieldGroup, `Minimum ${minLength} caractères requis`);
            return false;
        }

        hideFieldError(fieldGroup);
        return true;
    }

    // Afficher l'erreur du champ
    function showFieldError(element, message) {
        const group = element instanceof HTMLElement ? element : document.getElementById(element);
        if (!group) return;

        group.classList.add('error');
        group.classList.remove('success');

        const errorSpan = group.querySelector('.validation-error');
        if (errorSpan) {
            errorSpan.textContent = message;
        }
    }

    // Masquer l'erreur du champ
    function hideFieldError(element) {
        const group = element instanceof HTMLElement ? element : document.getElementById(element);
        if (!group) return;

        group.classList.remove('error');
        group.classList.add('success');

        const errorSpan = group.querySelector('.validation-error');
        if (errorSpan) {
            errorSpan.textContent = '';
        }
    }

    // Mettre à jour le stepper
    function updateStepper(step) {
        currentStep = step;

        // Mettre à jour les classes CSS
        for (let i = 1; i <= 3; i++) {
            const stepElement = document.getElementById(`step${i}`);
            const line = stepElement.nextElementSibling;

            if (i < step) {
                stepElement.classList.add('completed');
                stepElement.classList.remove('active');
                if (line) line.classList.add('active');
            } else if (i === step) {
                stepElement.classList.add('active');
                stepElement.classList.remove('completed');
            } else {
                stepElement.classList.remove('active', 'completed');
                if (line) line.classList.remove('active');
            }
        }
    }

    // Afficher le loading
    function showLoading(message = 'Traitement du paiement...', subtext = 'Veuillez patienter') {
        const overlay = document.getElementById('loadingOverlay');
        document.getElementById('loadingSubtext').textContent = subtext;
        document.querySelector('.loading-text').textContent = message;
        overlay.classList.add('active');
    }

    // Masquer le loading
    function hideLoading() {
        const overlay = document.getElementById('loadingOverlay');
        overlay.classList.remove('active');
    }

    // Valider le formulaire de paiement par carte
    async function validateCardPayment() {
        const cardName = document.getElementById('cardName');
        let isValid = true;

        // Valider le nom
        if (!validateField(cardName)) {
            isValid = false;
        }

        // Valider les éléments Stripe si présents
        if (cardElement && expiryElement && cvcElement) {
            // Créer un token sans soumettre
            const { token, error } = await stripe.createToken(cardElement, {
                name: cardName.value
            });

            if (error) {
                showFieldError('card-element-group', error.message);
                isValid = false;
            }
        }

        return isValid;
    }

    // Gérer la soumission du formulaire
    async function handleFormSubmit(e) {
        e.preventDefault();

        if (isProcessingPayment) return;

        const termsCheckbox = document.getElementById('terms');
        const paymentMethod = document.querySelector('input[name="selectedPaymentMethod"]:checked').value;

        // Vérifier les conditions d'utilisation
        if (!termsCheckbox.checked) {
            alert('Veuillez accepter les conditions d\'utilisation');
            return;
        }

        // Valider selon la méthode de paiement
        if (paymentMethod === 'card') {
            const isValid = await validateCardPayment();
            if (!isValid) return;

            // Mettre à jour le stepper
            updateStepper(2);

            // Afficher le loading
            showLoading('Vérification de votre carte', 'Sécurisation du paiement...');

            try {
                // Créer un token Stripe
                if (stripe && cardElement) {
                    const { token, error } = await stripe.createToken(cardElement, {
                        name: document.getElementById('cardName').value
                    });

                    if (error) {
                        hideLoading();
                        showFieldError('card-element-group', error.message);
                        updateStepper(1);
                        return;
                    }

                    // Stocker le token
                    document.getElementById('stripeToken').value = token.id;

                    // Étape 3 : Confirmation
                    updateStepper(3);
                    showLoading('Finalisation du paiement...', 'Veuillez patienter');

                    // Attendre un peu avant de soumettre
                    setTimeout(() => {
                        document.getElementById('paymentForm').submit();
                    }, 1000);
                }
            } catch (error) {
                hideLoading();
                updateStepper(1);
                console.error('Erreur Stripe:', error);
                alert('Une erreur est survenue. Veuillez réessayer.');
            }
        } else if (paymentMethod === 'paypal') {
            updateStepper(2);
            showLoading('Redirection vers PayPal...', 'Veuillez patienter');

            setTimeout(() => {
                document.getElementById('paymentForm').submit();
            }, 1500);
        } else if (paymentMethod === 'transfer') {
            updateStepper(2);
            showLoading('Préparation de votre virement...', 'Veuillez patienter');

            setTimeout(() => {
                document.getElementById('paymentForm').submit();
            }, 1500);
        }
    }
</script>

