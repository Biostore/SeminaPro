@page
@model AboutModel
@{
    ViewData["Title"] = "À Propos - SeminaPro";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<style>
    body {
        margin: 0;
        font-family: "Segoe UI", sans-serif;
        background: #f8fafc;
        color: #0f172a;
    }

    .page {
        max-width: 1100px;
        margin: auto;
        padding: 30px 20px;
    }

    /* HERO */
    .hero {
        background: linear-gradient(135deg, #0f172a, #1e3a8a);
        color: white;
        padding: 55px 20px;
        border-radius: 18px;
        text-align: center;
        position: relative;
        overflow: hidden;
        margin-bottom: 40px; /* 🔥 ESPACE IMPORTANT */
    }

        .hero::before {
            content: "";
            position: absolute;
            width: 300px;
            height: 300px;
            background: rgba(59,130,246,0.25);
            filter: blur(90px);
            top: -80px;
            right: -80px;
            border-radius: 50%;
        }

    .hero-content {
        position: relative;
        z-index: 2;
    }

    .hero h1 {
        font-size: 32px;
        font-weight: 800;
        margin-bottom: 10px;
    }

    .hero p {
        font-size: 15px;
        color: rgba(255,255,255,0.75);
    }

    /* SECTIONS */
    .section {
        margin-bottom: 50px; /* 🔥 ESPACE ENTRE BLOCS */
    }

    .section-title {
        text-align: center;
        font-size: 22px;
        font-weight: 700;
        margin-bottom: 18px;
    }

    .text {
        max-width: 750px;
        margin: auto;
        text-align: center;
        font-size: 14px;
        color: #64748b;
        line-height: 1.7;
    }

    /* CARDS */
    .grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 18px;
        margin-top: 25px;
    }

    @@media (max-width: 900px) {
        .grid {
            grid-template-columns: 1fr;
        }
    }

    .card {
        background: white;
        border: 1px solid #e2e8f0;
        border-radius: 14px;
        padding: 18px;
        text-align: center;
        transition: 0.25s;
    }

        .card:hover {
            transform: translateY(-6px);
            box-shadow: 0 15px 30px rgba(15,23,42,0.1);
        }

    .icon {
        width: 44px;
        height: 44px;
        margin: auto;
        background: #eef2ff;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #3b82f6;
        margin-bottom: 10px;
    }

    .card h3 {
        font-size: 15px;
        margin-bottom: 5px;
    }

    .card p {
        font-size: 13px;
        color: #64748b;
    }

    /* CTA */
    .cta {
        margin-top: 60px; /* 🔥 gros espace avant CTA */
        text-align: center;
        background: white;
        border: 1px solid #e2e8f0;
        padding: 40px;
        border-radius: 16px;
    }

        .cta h3 {
            margin-bottom: 10px;
            font-size: 20px;
        }

        .cta p {
            color: #64748b;
            font-size: 13px;
            margin-bottom: 20px;
        }

    .btn {
        display: inline-block;
        padding: 10px 14px;
        border-radius: 10px;
        font-weight: 600;
        text-decoration: none;
        margin: 5px;
        font-size: 13px;
    }

    .btn-primary {
        background: #3b82f6;
        color: white;
    }

    .btn-outline {
        border: 1px solid #3b82f6;
        color: #3b82f6;
    }

</style>

<div class="page">

    <!-- HERO -->
    <div class="hero">
        <div class="hero-content">
            <h1>À Propos de SeminaPro</h1>
            <p>
                Plateforme moderne de gestion de séminaires professionnels,
                simple, rapide et efficace.
            </p>
        </div>
    </div>

    <!-- QUI SOMMES-NOUS -->
    <div class="section">
        <h2 class="section-title">Qui sommes-nous ?</h2>
        <p class="text">
            SeminaPro simplifie la gestion des séminaires professionnels en offrant une plateforme
            intuitive pour connecter organisateurs et participants.
        </p>
    </div>

    <!-- VALEURS -->
    <div class="section">

        <h2 class="section-title">Nos Valeurs</h2>

        <div class="grid">

            <div class="card">
                <div class="icon"><i class="bi bi-star-fill"></i></div>
                <h3>Excellence</h3>
                <p>Qualité et performance.</p>
            </div>

            <div class="card">
                <div class="icon"><i class="bi bi-shield-check"></i></div>
                <h3>Fiabilité</h3>
                <p>Sécurité et stabilité.</p>
            </div>

            <div class="card">
                <div class="icon"><i class="bi bi-lightbulb"></i></div>
                <h3>Innovation</h3>
                <p>Technologie moderne.</p>
            </div>

        </div>

    </div>

    <!-- CTA -->
    <div class="cta">

        <h3>Rejoignez SeminaPro</h3>
        <p>Commencez à gérer vos séminaires facilement</p>

        <a class="btn btn-primary" href="/Seminaires/Index">VOIR SÉMINAIRES</a>
        <a class="btn btn-outline" href="/Contact">CONTACT</a>

    </div>

</div>