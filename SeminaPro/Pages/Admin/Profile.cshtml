@page
@model SeminaPro.Pages.Admin.ProfileModel
@{
    ViewData["Title"] = "Profil Admin";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<style>
    body {
        background: linear-gradient(135deg, #f6f8fc, #eef2ff);
        font-family: "Segoe UI", sans-serif;
        color: #0f172a;
    }

    .page {
        padding: 28px;
        animation: fadeIn 0.4s ease;
    }

    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }

    /* HEADER */
    .header {
        margin-bottom: 20px;
    }

    .header h1 {
        font-size: 24px;
        font-weight: 800;
    }

    .header p {
        color: #64748b;
        font-size: 13px;
    }

    /* PROFILE CARD */
    .profile-card {
        background: white;
        border-radius: 16px;
        border: 1px solid #eef2f7;
        box-shadow: 0 10px 25px rgba(0,0,0,0.05);
        text-align: center;
        padding: 20px;
        transition: 0.3s;
    }

    .profile-card:hover {
        transform: translateY(-4px);
    }

    .profile-img {
        width: 110px;
        height: 110px;
        border-radius: 50%;
        object-fit: cover;
        border: 4px solid #3b82f6;
        margin-bottom: 12px;
    }

    .badge-admin {
        background: #3b82f6;
        color: white;
        font-size: 11px;
        padding: 4px 10px;
        border-radius: 20px;
        display: inline-block;
        margin-top: 6px;
    }

    /* FORM CARD */
    .form-card {
        background: white;
        border-radius: 16px;
        border: 1px solid #eef2f7;
        box-shadow: 0 10px 25px rgba(0,0,0,0.05);
        padding: 20px;
        transition: 0.3s;
    }

    .form-card:hover {
        box-shadow: 0 15px 35px rgba(0,0,0,0.08);
    }

    .form-header {
        font-weight: 700;
        margin-bottom: 15px;
        font-size: 15px;
    }

    .form-control {
        border-radius: 10px;
        border: 1px solid #e2e8f0;
        padding: 10px;
        font-size: 14px;
    }

    .form-control:focus {
        border-color: #3b82f6;
        box-shadow: 0 0 0 3px rgba(59,130,246,0.2);
    }

    /* BUTTONS */
    .btn {
        border-radius: 10px;
        font-size: 13px;
        padding: 8px 14px;
        transition: 0.2s;
    }

    .btn-primary {
        background: #3b82f6;
        border: none;
    }

    .btn-primary:hover {
        background: #2563eb;
        transform: scale(1.03);
    }

    .btn-secondary {
        background: #f1f5f9;
        border: none;
        color: #0f172a;
    }

    .btn-secondary:hover {
        background: #e2e8f0;
    }

</style>

<div class="page">

    <!-- HEADER -->
    <div class="header">
        <h1><i class="bi bi-person-circle"></i> Mon Profil</h1>
        <p>Gérez et mettez à jour vos informations personnelles</p>
    </div>

    <div class="row g-4">

        <!-- LEFT PROFILE -->
        <div class="col-md-4">

            <div class="profile-card">

                <img src="~/images/default-profile.png" class="profile-img" />

                <h5 class="mt-2">@Model.Prenom @Model.Nom</h5>
                <p style="color:#64748b;font-size:13px">@Model.Email</p>

                <span class="badge-admin">
                    <i class="bi bi-shield-check"></i> Administrateur
                </span>

            </div>

        </div>

        <!-- RIGHT FORM -->
        <div class="col-md-8">

            <div class="form-card">

                <div class="form-header">
                    <i class="bi bi-person-lines-fill"></i> Informations personnelles
                </div>

                <form method="post">

                    <div class="row g-3">

                        <div class="col-md-6">
                            <label class="form-label">Prénom</label>
                            <input class="form-control" asp-for="Prenom" />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Nom</label>
                            <input class="form-control" asp-for="Nom" />
                        </div>

                        <div class="col-md-12">
                            <label class="form-label">Email</label>
                            <input class="form-control" asp-for="Email" type="email" />
                        </div>

                        <div class="col-md-12 d-flex justify-content-end gap-2 mt-2">

                            <a href="/Admin/Dashboard" class="btn btn-secondary">
                                <i class="bi bi-x-circle"></i> Annuler
                            </a>

                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-check-circle"></i> Mettre à jour
                            </button>

                        </div>

                    </div>

                </form>

            </div>

        </div>

    </div>

</div>