@page
@model SeminaPro.Pages.Admin.SeminairesModel
@{
    ViewData["Title"] = "Gestion des Séminaires";
}

<!-- PAGE HEADER -->
<div class="admin-page-header">
    <div>
        <h1>Gestion des Séminaires</h1>
        <p>Gérez et organisez l'ensemble de vos séminaires</p>
    </div>
    <a class="btn-add-action" asp-page="CreateSeminaire">
        <i class="bi bi-plus-lg"></i> Ajouter un Séminaire
    </a>
</div>

<!-- MESSAGES -->
@if (!string.IsNullOrEmpty(ViewData["Message"]?.ToString()))
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle"></i>
        @ViewData["Message"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- SEARCH & FILTER -->
<div class="admin-search-filter">
    <div class="search-box">
        <input type="text" id="searchInput" class="form-control" placeholder="🔍 Rechercher par titre ou code...">
    </div>
    <div class="filter-box">
        <select id="filterLieu" class="form-control">
            <option value="">Tous les lieux</option>
            @if (Model.Seminaires?.Count > 0)
            {
                @foreach (var lieu in Model.Seminaires.Select(s => s.Lieu).Distinct())
                {
                    <option value="@lieu">@lieu</option>
                }
            }
        </select>
    </div>
</div>

<!-- TABLE -->
<div class="table-responsive">
    <table class="table admin-table">
        <thead>
            <tr>
                <th>Code</th>
                <th>Titre</th>
                <th>Lieu</th>
                <th>Date</th>
                <th>Tarif</th>
                <th>Inscrits</th>
                <th style="text-align: center;">Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Seminaires?.Count > 0)
            {
                @foreach (var seminaire in Model.Seminaires)
                {
                    var inscriptions = seminaire.Inscriptions?.Count ?? 0;
                    var max = seminaire.NombreMaximal;
                    var pourcentage = max > 0 ? (inscriptions * 100) / max : 0;
                    var badgeClass = pourcentage < 50 ? "low" : pourcentage < 80 ? "medium" : "high";

                    <tr>
                        <!-- Code -->
                        <td>
                            <span class="seminar-code">@seminaire.Code</span>
                        </td>

                        <!-- Titre -->
                        <td>
                            <strong>@seminaire.Titre</strong>
                        </td>

                        <!-- Lieu -->
                        <td>@seminaire.Lieu</td>

                        <!-- Date -->
                        <td>@seminaire.DateSeminaire.ToString("dd/MM/yyyy")</td>

                        <!-- Prix -->
                        <td class="price-cell">@seminaire.Tarif.ToString("0.00") DT</td>

                        <!-- Inscrits -->
                        <td>
                            <span class="inscriptions-badge @badgeClass">
                                @inscriptions / @max
                            </span>
                        </td>

                        <!-- Actions -->
                        <td>
                            <div class="actions-column">
                                <a class="btn-action btn-edit" asp-page="EditSeminaire" asp-route-id="@seminaire.Id" title="Éditer ce séminaire">
                                    <i class="bi bi-pencil"></i> Éditer
                                </a>
                                <form method="post" asp-page-handler="Delete" asp-route-id="@seminaire.Id" 
                                      style="display:inline;" onsubmit="return confirm('⚠️ Êtes-vous sûr de vouloir supprimer ce séminaire ?')">
                                    <button type="submit" class="btn-action btn-delete" title="Supprimer ce séminaire">
                                        <i class="bi bi-trash3"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="7">
                        <div class="empty-state">
                            <i class="bi bi-inbox"></i>
                            <p>Aucun séminaire trouvé</p>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- Script pour recherche et filtrage -->
<script>
    document.getElementById('searchInput')?.addEventListener('keyup', function () {
        const searchValue = this.value.toLowerCase();
        const filterValue = document.getElementById('filterLieu')?.value || '';

        document.querySelectorAll('.admin-table tbody tr').forEach(row => {
            if (row.querySelector('.empty-state')) return;

            const titre = row.cells[1].textContent.toLowerCase();
            const code = row.cells[0].textContent.toLowerCase();
            const lieu = row.cells[2].textContent.toLowerCase();

            const matchSearch = titre.includes(searchValue) || code.includes(searchValue);
            const matchFilter = !filterValue || lieu === filterValue;

            row.style.display = matchSearch && matchFilter ? '' : 'none';
        });
    });

    document.getElementById('filterLieu')?.addEventListener('change', function () {
        const filterValue = this.value.toLowerCase();
        const searchValue = document.getElementById('searchInput')?.value.toLowerCase() || '';

        document.querySelectorAll('.admin-table tbody tr').forEach(row => {
            if (row.querySelector('.empty-state')) return;

            const titre = row.cells[1].textContent.toLowerCase();
            const code = row.cells[0].textContent.toLowerCase();
            const lieu = row.cells[2].textContent.toLowerCase();

            const matchSearch = titre.includes(searchValue) || code.includes(searchValue);
            const matchFilter = !filterValue || lieu === filterValue;

            row.style.display = matchSearch && matchFilter ? '' : 'none';
        });
    });
</script>

