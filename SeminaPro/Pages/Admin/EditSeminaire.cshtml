@page "{id:int}"
@model SeminaPro.Pages.Admin.EditSeminaireModel
@{
    ViewData["Title"] = "Éditer un Séminaire";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">

<style>
    body {
        background: linear-gradient(135deg, #163b73, #2f5fa7, #4b7fd1);
        min-height: 100vh;
        font-family: 'Segoe UI';
    }

    .edit-container {
        max-width: 800px;
        margin: 60px auto;
    }

    .card {
        border-radius: 18px;
        padding: 30px;
        background: white;
        box-shadow: 0 10px 30px rgba(0,0,0,0.25);
    }

    .title {
        text-align: center;
        font-weight: 800;
        color: #0f172a;
        margin-bottom: 20px;
    }

    .preview-img {
        width: 100%;
        max-height: 220px;
        object-fit: cover;
        border-radius: 12px;
        margin-bottom: 15px;
    }

    .btn-save {
        background: #2563eb;
        color: white;
        padding: 10px 18px;
        border-radius: 10px;
        border: none;
        font-weight: 600;
    }

    .btn-cancel {
        background: #e5e7eb;
        padding: 10px 18px;
        border-radius: 10px;
        margin-left: 10px;
        text-decoration: none;
        color: #111;
    }

    .form-control {
        border-radius: 10px;
        height: 42px;
    }
</style>

<div class="edit-container">

    <div class="card">

        <h2 class="title">✏️ Éditer un Séminaire</h2>

        @if (!string.IsNullOrEmpty(Model.Seminaire?.ImageUrl))
        {
            <img src="@Model.Seminaire.ImageUrl" class="preview-img" />
        }

        <form method="post" enctype="multipart/form-data">

            <input type="hidden" asp-for="Seminaire.Id" />

            <div class="mb-3">
                <label>Code</label>
                <input asp-for="Seminaire.Code" class="form-control" />
            </div>

            <div class="mb-3">
                <label>Titre</label>
                <input asp-for="Seminaire.Titre" class="form-control" />
            </div>

            <div class="mb-3">
                <label>Lieu</label>
                <input asp-for="Seminaire.Lieu" class="form-control" />
            </div>

            <div class="mb-3">
                <label>Tarif</label>
                <input asp-for="Seminaire.Tarif" class="form-control" />
            </div>

            <div class="mb-3">
                <label>Date</label>
                <input asp-for="Seminaire.DateSeminaire" type="date" class="form-control" />
            </div>

            <div class="mb-3">
                <label>Nombre max</label>
                <input asp-for="Seminaire.NombreMaximal" class="form-control" />
            </div>

            <!-- IMAGE -->
            <div class="mb-3">
                <label>Image du séminaire</label>
                <input type="file" name="imageFile" class="form-control" />
            </div>

            <button type="submit" class="btn-save">
                <i class="bi bi-check-circle"></i> Enregistrer
            </button>

            <a asp-page="Seminaires" class="btn-cancel">Annuler</a>

        </form>

    </div>
</div>