@page
@model SeminaPro.Pages.Admin.CalendrierModel
@{
    ViewData["Title"] = "Calendrier des Séminaires";

    var now = DateTime.Now;
    var aVenir = Model.Seminaires.Where(s => s.DateSeminaire >= now).ToList();
    var passes = Model.Seminaires.Where(s => s.DateSeminaire < now).ToList();
}

<link rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

<div class="cal-page">

    <!-- HEADER -->
    <div class="cal-header">

        <div>
            <h1>Calendrier des Séminaires</h1>
            <p>Gestion intelligente des événements</p>
        </div>

        <a href="/Admin/CreateSeminaire" class="btn-primary">
            <i class="bi bi-plus-circle"></i> Nouveau
        </a>

    </div>

    <!-- TABS -->
    <div class="tabs">

        <button class="tab active" id="tab1" onclick="showTab('cal')">
            📅 Calendrier
        </button>

        <button class="tab" id="tab2" onclick="showTab('list')">
            📋 Liste
        </button>

    </div>

    <!-- CALENDAR -->
    <div id="cal-view" class="card">

        <div id="calendar"></div>

    </div>

    <!-- LIST -->
    <div id="list-view" class="card" style="display:none;">

        <h3 class="title-blue">À venir (@aVenir.Count)</h3>

        @foreach (var s in aVenir.OrderBy(x => x.DateSeminaire))
        {
            <div class="item">

                <div>
                    <div class="item-title">@s.Titre</div>
                    <div class="item-meta">
                        📍 @s.Lieu • 📅 @s.DateSeminaire.ToString("dd/MM/yyyy")
                    </div>
                </div>

                <div class="actions">

                    <a href="/Admin/EditSeminaire?id=@s.Id" class="btn edit">
                        <i class="bi bi-pencil"></i>
                    </a>

                    <button onclick="deleteSem(@s.Id,'@s.Titre')" class="btn delete">
                        <i class="bi bi-trash"></i>
                    </button>

                </div>

            </div>
        }

        <hr />

        <h3 class="title-muted">Passés (@passes.Count)</h3>

        @foreach (var s in passes.OrderByDescending(x => x.DateSeminaire))
        {
            <div class="item muted">

                <div>
                    <div class="item-title">@s.Titre</div>
                    <div class="item-meta">
                        📍 @s.Lieu • 📅 @s.DateSeminaire.ToString("dd/MM/yyyy")
                    </div>
                </div>

                <div class="actions">

                    <button onclick="deleteSem(@s.Id,'@s.Titre')" class="btn delete">
                        <i class="bi bi-trash"></i>
                    </button>

                </div>

            </div>
        }

    </div>

</div>

<!-- FULLCALENDAR -->
<link href="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.8/index.global.min.css" rel="stylesheet" />
<script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.8/index.global.min.js"></script>

<script>

    let calendar;

    document.addEventListener('DOMContentLoaded', function () {

    const el = document.getElementById('calendar');

    calendar = new FullCalendar.Calendar(el, {

    initialView: 'dayGridMonth',
    locale: 'fr',
    height: 700,

    headerToolbar: {
    left: 'prev,next today',
    center: 'title',
    right: 'dayGridMonth,timeGridWeek'
    },

    events: [
    @foreach (var s in Model.Seminaires)
    {
        <text>{
            title: '@s.Titre',
            start: '@s.DateSeminaire.ToString("yyyy-MM-dd")',
            color: '@(s.DateSeminaire >= DateTime.Now ? "#1e3a8a" : "#94a3b8")'
            },</text>
        }
        ]
        });

        calendar.render();
        });

        // TAB FIX
        function showTab(tab) {

        document.getElementById('cal-view').style.display =
        tab === 'cal' ? 'block' : 'none';

        document.getElementById('list-view').style.display =
        tab === 'list' ? 'block' : 'none';

        document.getElementById('tab1').classList.toggle('active', tab === 'cal');
        document.getElementById('tab2').classList.toggle('active', tab === 'list');

        if (calendar) {
        setTimeout(() => calendar.updateSize(), 100);
        }
        }

        // DELETE
        function deleteSem(id, title) {

        if (!confirm("Supprimer : " + title + " ?")) return;

        fetch('/Admin/Calendrier?id=' + id + '&handler=Delete', {
        method: 'POST'
        }).then(() => location.reload());
        }

    </script>

    <style>

        /* ===== PAGE ===== */
        .cal-page {
        padding: 25px;
        background: #f5f7ff;
        font-family: Segoe UI;
        }

        /* HEADER */
        .cal-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
        }

        .cal-header h1 {
        color: #0f172a;
        font-size: 22px;
        font-weight: 700;
        }

        .cal-header p {
        color: #64748b;
        }

        /* BUTTON */
        .btn-primary {
        background: #1e3a8a;
        color: white;
        padding: 10px 15px;
        border-radius: 10px;
        text-decoration: none;
        font-weight: 600;
        }

        /* TABS */
        .tabs {
        display: flex;
        gap: 10px;
        margin-bottom: 15px;
        }

        .tab {
        flex: 1;
        padding: 10px;
        border-radius: 10px;
        border: 1px solid #e2e8f0;
        background: white;
        cursor: pointer;
        font-weight: 500;
        }

        .tab.active {
        background: #1e3a8a;
        color: white;
        }

        /* CARD */
        .card {
        background: white;
        border-radius: 14px;
        padding: 15px;
        box-shadow: 0 8px 20px rgba(0,0,0,0.05);
        }

        /* LIST */
        .item {
        display: flex;
        justify-content: space-between;
        padding: 12px;
        border-bottom: 1px solid #f1f5f9;
        }

        .item:last-child {
        border: none;
        }

        .item-title {
        font-weight: 600;
        color: #0f172a;
        }

        .item-meta {
        font-size: 12px;
        color: #64748b;
        }

        .muted {
        opacity: 0.6;
        }

        /* ACTIONS */
        .actions {
        display: flex;
        gap: 8px;
        }

        .btn {
        width: 34px;
        height: 34px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 8px;
        text-decoration: none;
        border: none;
        }

        .edit {
        background: #dbeafe;
        color: #1d4ed8;
        }

        .delete {
        background: #fee2e2;
        color: #dc2626;
        }

        /* TITLES */
        .title-blue {
        color: #1e3a8a;
        }

        .title-muted {
        color: #94a3b8;
        }

        /* CALENDAR CLEAN */
        #calendar {
        min-height: 700px;
        }

        .fc {
        border: none !important;
        }

    </style>