@page "{id?}"
@model SeminaPro.Pages.Admin.SpecialitesModel
@{
    ViewData["Title"] = "Gestion des Spécialités";
}

<link rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

<div class="page-wrapper">

    <!-- HEADER -->
    <div class="header">

        <div>
            <h1>Gestion des Spécialités</h1>
            <p>Administration des spécialités</p>
        </div>

        <div class="counter">
            <span>@(Model.Specialites?.Count ?? 0)</span>
            <small>Total</small>
        </div>

    </div>

    <!-- ALERTS -->
    @if (!string.IsNullOrEmpty(TempData["Message"]?.ToString()))
    {
        <div class="alert success">
            <i class="bi bi-check-circle-fill"></i>
            @TempData["Message"]
        </div>
    }

    @if (!string.IsNullOrEmpty(TempData["Error"]?.ToString()))
    {
        <div class="alert error">
            <i class="bi bi-exclamation-circle-fill"></i>
            @TempData["Error"]
        </div>
    }

    <div class="grid">

        <!-- FORM -->
        <div class="card">

            <div class="card-header">
                <h3>
                    @(Model.Specialite?.Id > 0 ? "Modifier Spécialité" : "Ajouter Spécialité")
                </h3>
                <p>Remplir les informations</p>
            </div>

            <form method="post" asp-page-handler="Save">

                <input type="hidden" asp-for="Specialite.Id" />

                <label>Libellé</label>
                <input asp-for="Specialite.Libelle" class="input" />

                <label>Abréviation</label>
                <input asp-for="Specialite.Abbreviation" class="input" />

                <label>Description</label>
                <textarea asp-for="Specialite.Description" class="input"></textarea>

                <button type="submit" class="btn-primary">
                    Enregistrer
                </button>

            </form>

        </div>

        <!-- TABLE -->
        <div class="card">

            <div class="card-header">
                <h3>Liste des Spécialités</h3>
                <p>Gestion complète</p>
            </div>

            @if (Model.Specialites != null && Model.Specialites.Count > 0)
            {
                <table>

                    <thead>
                        <tr>
                            <th>Spécialité</th>
                            <th>Abr.</th>
                            <th>Description</th>
                            <th>Participants</th>
                            <th>Séminaires</th>
                            <th>Actions</th>
                        </tr>
                    </thead>

                    <tbody>

                        @foreach (var s in Model.Specialites)
                        {
                            <tr>

                                <td>
                                    <div class="flex">
                                        <div class="icon">🎓</div>
                                        <strong>@s.Libelle</strong>
                                    </div>
                                </td>

                                <td>
                                    <span class="badge">@s.Abbreviation</span>
                                </td>

                                <td>
                                    @(string.IsNullOrEmpty(s.Description)
                                        ? "-"
                                        : (s.Description.Length > 40
                                            ? s.Description.Substring(0, 40) + "..."
                                            : s.Description))
                                </td>

                                <td>@s.Participants.Count</td>
                                <td>@s.Seminaires.Count</td>

                                <td>

                                    <!-- EDIT FIX IMPORTANT -->
                                    <a asp-page="./Specialites"
                                           asp-route-id="@s.Id"
                                           class="btn edit">
                                        <i class="bi bi-pencil"></i>
                                    </a>

                                    <!-- DELETE -->
                                    <form method="post"
                                          asp-page-handler="Delete"
                                          asp-route-id="@s.Id"
                                          class="inline">

                                        <button class="btn delete"
                                                onclick="return confirm('Supprimer ?')">
                                            <i class="bi bi-trash"></i>
                                        </button>

                                    </form>

                                </td>

                            </tr>
                        }

                    </tbody>

                </table>
            }
            else
            {
                <div class="empty">
                    Aucune spécialité disponible
                </div>
            }

        </div>

    </div>

</div>

<style>

    body {
        margin: 0;
        font-family: Segoe UI;
        background: #f5f7ff;
    }

    /* HEADER */
    .header {
        display: flex;
        justify-content: space-between;
        margin-bottom: 20px;
    }

        .header h1 {
            color: #0f172a;
            font-size: 24px;
        }

        .header p {
            color: #64748b;
        }

    .counter {
        width: 65px;
        height: 65px;
        background: #1e3a8a;
        color: white;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        border-radius: 12px;
    }

    /* GRID */
    .grid {
        display: grid;
        grid-template-columns: 1fr 2fr;
        gap: 20px;
    }

    /* CARD */
    .card {
        background: white;
        border-radius: 12px;
        padding: 20px;
        border: 1px solid #e5e7eb;
    }

    .card-header h3 {
        color: #1e3a8a;
        margin: 0;
    }

    .card-header p {
        color: #64748b;
        font-size: 13px;
    }

    /* INPUT */
    .input {
        width: 100%;
        padding: 10px;
        margin-bottom: 12px;
        border: 1px solid #cbd5e1;
        border-radius: 8px;
    }

        .input:focus {
            outline: none;
            border-color: #1d4ed8;
            box-shadow: 0 0 0 3px rgba(29,78,216,0.2);
        }

    /* BUTTON */
    .btn-primary {
        width: 100%;
        padding: 10px;
        background: #1e3a8a;
        color: white;
        border: none;
        border-radius: 8px;
    }

    /* TABLE */
    table {
        width: 100%;
        border-collapse: collapse;
    }

    thead {
        background: #1e3a8a;
        color: white;
    }

    th, td {
        padding: 10px;
    }

    /* FLEX */
    .flex {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .icon {
        width: 30px;
        height: 30px;
        background: #dbeafe;
        border-radius: 6px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    /* BADGE */
    .badge {
        background: #dbeafe;
        color: #1d4ed8;
        padding: 4px 8px;
        border-radius: 6px;
        font-size: 12px;
    }

    /* ACTIONS */
    .btn {
        width: 32px;
        height: 32px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 6px;
    }

    .edit {
        background: #dbeafe;
        color: #1d4ed8;
    }

    .delete {
        background: #fee2e2;
        color: #dc2626;
        border: none;
    }

    /* INLINE FORM */
    .inline {
        display: inline;
    }

    /* ALERT */
    .success {
        background: #ecfdf5;
        color: #047857;
        padding: 10px;
        border-radius: 8px;
        margin-bottom: 10px;
    }

    .error {
        background: #fef2f2;
        color: #b91c1c;
        padding: 10px;
        border-radius: 8px;
        margin-bottom: 10px;
    }

    /* EMPTY */
    .empty {
        text-align: center;
        padding: 30px;
        color: #64748b;
    }

</style>