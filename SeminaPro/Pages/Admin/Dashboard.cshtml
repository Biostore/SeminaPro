@page
@model SeminaPro.Pages.Admin.DashboardModel
@{
    ViewData["Title"] = "Dashboard";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<style>
    body {
        background: #f6f8fc;
        font-family: "Segoe UI", sans-serif;
        color: #0f172a;
    }

    .page {
        padding: 24px;
        animation: fadeIn 0.4s ease;
    }

    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }

    /* HEADER */
    .header h1 {
        font-size: 24px;
        font-weight: 800;
    }

    .header p {
        color: #64748b;
        font-size: 13px;
    }

    /* STATS */
    .stats {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 12px;
        margin: 16px 0;
    }

    @@media (max-width: 900px) {
        .stats { grid-template-columns: repeat(2, 1fr); }
    }

    @@media (max-width: 600px) {
        .stats { grid-template-columns: 1fr; }
    }

    .card {
        background: white;
        border-radius: 12px;
        padding: 12px;
        display: flex;
        gap: 10px;
        align-items: center;
        border: 1px solid #eef2f7;
        transition: 0.2s;
    }

    .card:hover {
        transform: translateY(-3px);
        box-shadow: 0 8px 18px rgba(0,0,0,0.08);
    }

    .icon {
        width: 34px;
        height: 34px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 14px;
    }

    .blue { background: #3b82f6; }
    .green { background: #10b981; }
    .purple { background: #8b5cf6; }
    .orange { background: #f59e0b; }

    .info h3 {
        margin: 0;
        font-size: 16px;
        font-weight: 700;
    }

    .info span {
        font-size: 11px;
        color: #64748b;
    }

    /* CHARTS */
    .charts {
        display: grid;
        grid-template-columns: 1.5fr 1fr;
        gap: 12px;
        margin-bottom: 16px;
    }

    @@media (max-width: 900px) {
        .charts { grid-template-columns: 1fr; }
    }

    .box {
        background: white;
        border-radius: 12px;
        border: 1px solid #eef2f7;
        padding: 12px;
    }

    .box h4 {
        margin-bottom: 8px;
        font-size: 13px;
        font-weight: 700;
    }

    canvas {
        max-height: 180px !important; /* 🔥 IMPORTANT : réduit taille */
    }

    /* LIST */
    .item {
        display: flex;
        justify-content: space-between;
        padding: 8px 0;
        border-bottom: 1px solid #f1f5f9;
        font-size: 13px;
    }

    .item:last-child { border: none; }

    .btn {
        background: #3b82f6;
        color: white;
        padding: 5px 8px;
        border-radius: 6px;
        font-size: 11px;
        text-decoration: none;
    }

    .btn-soft {
        background: #f1f5f9;
        color: #0f172a;
    }
</style>

<div class="page">

    <!-- HEADER -->
    <div class="header">
        <h1>Dashboard</h1>
        <p>Vue globale de votre plateforme</p>
    </div>

    <!-- STATS -->
    <div class="stats">

        <div class="card">
            <div class="icon blue"><i class="bi bi-book"></i></div>
            <div class="info">
                <h3>@Model.TotalSeminaires</h3>
                <span>Séminaires</span>
            </div>
        </div>

        <div class="card">
            <div class="icon green"><i class="bi bi-people"></i></div>
            <div class="info">
                <h3>@Model.TotalParticipants</h3>
                <span>Participants</span>
            </div>
        </div>

        <div class="card">
            <div class="icon purple"><i class="bi bi-check2-circle"></i></div>
            <div class="info">
                <h3>@Model.TotalInscriptions</h3>
                <span>Inscriptions</span>
            </div>
        </div>

        <div class="card">
            <div class="icon orange"><i class="bi bi-tags"></i></div>
            <div class="info">
                <h3>@Model.TotalSpecialites</h3>
                <span>Spécialités</span>
            </div>
        </div>

    </div>

    <!-- CHARTS -->
    <div class="charts">

        <!-- BAR -->
        <div class="box">
            <h4>Statistiques générales</h4>
            <canvas id="barChart"></canvas>
        </div>

        <!-- LINE (différent graphe ✔) -->
        <div class="box">
            <h4>Évolution (simulation)</h4>
            <canvas id="lineChart"></canvas>
        </div>

    </div>

    <!-- CONTENT -->
    <div class="box">

        <h4>Derniers séminaires</h4>

        @foreach (var s in Model.DerniersSeminaires.Take(5))
        {
            <div class="item">
                <div>
                    <strong>@s.Titre</strong><br />
                    <small style="color:#64748b">@s.DateSeminaire.ToString("dd/MM/yyyy")</small>
                </div>

                <a class="btn" href="/Admin/EditSeminaire?id=@s.Id">Edit</a>
            </div>
        }

    </div>

</div>

<!-- JS CHARTS -->
<script>
    /* BAR CHART */
    new Chart(document.getElementById('barChart'), {
        type: 'bar',
        data: {
            labels: ['Séminaires', 'Participants', 'Inscriptions', 'Spécialités'],
            datasets: [{
                data: [
                    @Model.TotalSeminaires,
                    @Model.TotalParticipants,
                    @Model.TotalInscriptions,
                    @Model.TotalSpecialites
                ],
                backgroundColor: ['#3b82f6','#10b981','#8b5cf6','#f59e0b']
            }]
        },
        options: {
            plugins: { legend: { display: false } },
            responsive: true
        }
    });

    /* LINE CHART (différent ✔) */
    new Chart(document.getElementById('lineChart'), {
        type: 'line',
        data: {
            labels: ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun'],
            datasets: [{
                label: 'Activité',
                data: [5, 12, 8, 15, 20, @Model.TotalSeminaires],
                borderColor: '#3b82f6',
                tension: 0.4,
                fill: true,
                backgroundColor: 'rgba(59,130,246,0.1)'
            }]
        },
        options: {
            responsive: true,
            plugins: { legend: { display: false } }
        }
    });
</script>