@page
@model SeminaPro.Pages.Admin.DashboardModel
@{
    ViewData["Title"] = "Dashboard";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<style>

body{
    background:#f6f8fc;
    font-family:"Segoe UI";
    color:#0f172a;
}

.page{
    padding:24px;
}

/* HEADER */
.header h1{
    font-size:26px;
    font-weight:800;
}

.header p{
    color:#64748b;
    font-size:13px;
}

/* STATS */
.stats{
    display:grid;
    grid-template-columns:repeat(4,1fr);
    gap:12px;
    margin:16px 0;
}

/* ✅ FIX RAZOR ERROR => @@media */
@@media (max-width: 900px){
    .stats{
        grid-template-columns:repeat(2,1fr);
    }
}

@@media (max-width: 600px){
    .stats{
        grid-template-columns:1fr;
    }
}

.card{
    background:white;
    border-radius:12px;
    padding:12px;
    display:flex;
    gap:10px;
    align-items:center;
    border:1px solid #eef2f7;
    transition:0.2s;
}

.card:hover{
    transform:translateY(-3px);
    box-shadow:0 8px 18px rgba(0,0,0,0.08);
}

.icon{
    width:34px;
    height:34px;
    border-radius:8px;
    display:flex;
    align-items:center;
    justify-content:center;
    color:white;
    font-size:14px;
}

.blue{background:#1e3a8a;}
.green{background:#10b981;}
.purple{background:#8b5cf6;}
.orange{background:#f59e0b;}

.info h3{
    margin:0;
    font-size:16px;
    font-weight:700;
}

.info span{
    font-size:11px;
    color:#64748b;
}

/* CHARTS */
.charts{
    display:grid;
    grid-template-columns:1.5fr 1fr;
    gap:12px;
    margin-bottom:16px;
}

@@media (max-width: 900px){
    .charts{
        grid-template-columns:1fr;
    }
}

.box{
    background:white;
    border-radius:12px;
    border:1px solid #eef2f7;
    padding:12px;
}

.box h4{
    font-size:13px;
    font-weight:700;
}

canvas{
    max-height:180px !important;
}

/* SEMINAIRE ITEM */
.seminaire-item{
    display:flex;
    gap:12px;
    padding:10px;
    border-bottom:1px solid #eef2f7;
    align-items:center;
    transition:0.2s;
}

.seminaire-item:hover{
    background:#f8fafc;
}

.seminaire-item img{
    width:60px;
    height:60px;
    border-radius:10px;
    object-fit:cover;
    border:1px solid #e2e8f0;
}

.info-box{
    flex:1;
    display:flex;
    justify-content:space-between;
    align-items:center;
}

.info-box strong{
    font-size:13px;
}

.info-box small{
    font-size:11px;
    color:#64748b;
}

/* BUTTON */
.btn{
    background:#1e3a8a;
    color:white;
    padding:5px 10px;
    border-radius:8px;
    font-size:11px;
    text-decoration:none;
    display:flex;
    align-items:center;
    gap:5px;
}

.btn:hover{
    background:#1e40af;
}

</style>

<div class="page">

    <!-- HEADER -->
    <div class="header">
        <h1>Dashboard Admin</h1>
        <p>Vue globale de la plateforme</p>
    </div>

    <!-- STATS -->
    <div class="stats">

        <div class="card">
            <div class="icon blue"><i class="bi bi-book"></i></div>
            <div class="info">
                <h3>@Model.TotalSeminaires</h3>
                <span>Séminaires</span>
            </div>
        </div>

        <div class="card">
            <div class="icon green"><i class="bi bi-people"></i></div>
            <div class="info">
                <h3>@Model.TotalParticipants</h3>
                <span>Participants</span>
            </div>
        </div>

        <div class="card">
            <div class="icon purple"><i class="bi bi-check2-circle"></i></div>
            <div class="info">
                <h3>@Model.TotalInscriptions</h3>
                <span>Inscriptions</span>
            </div>
        </div>

        <div class="card">
            <div class="icon orange"><i class="bi bi-tags"></i></div>
            <div class="info">
                <h3>@Model.TotalSpecialites</h3>
                <span>Spécialités</span>
            </div>
        </div>

    </div>

    <!-- CHARTS -->
    <div class="charts">

        <div class="box">
            <h4>Statistiques</h4>
            <canvas id="barChart"></canvas>
        </div>

        <div class="box">
            <h4>Évolution</h4>
            <canvas id="lineChart"></canvas>
        </div>

    </div>

    <!-- LISTE SÉMINAIRES -->
    <div class="box">

        <h4>Derniers séminaires</h4>

        @foreach (var s in Model.DerniersSeminaires.Take(5))
        {
            <div class="seminaire-item">

                <!-- IMAGE -->
                <img src="@(string.IsNullOrEmpty(s.ImageUrl)
                            ? "/images/default-seminaire.jpg"
                            : s.ImageUrl)"
                     onerror="this.src='/images/default-seminaire.jpg'" />

                <!-- INFO -->
                <div class="info-box">

                    <div>
                        <strong>@s.Titre</strong><br />
                        <small>@s.DateSeminaire.ToString("dd/MM/yyyy")</small>
                    </div>

                    <!-- EDIT BUTTON FIXED -->
                    <a class="btn"
                       asp-page="/Admin/EditSeminaire"
                       asp-route-id="@s.Id">
                        <i class="bi bi-pencil"></i> Edit
                    </a>

                </div>

            </div>
        }

    </div>

</div>

<!-- CHART JS -->
<script>

new Chart(document.getElementById('barChart'), {
    type: 'bar',
    data: {
        labels: ['Séminaires','Participants','Inscriptions','Spécialités'],
        datasets: [{
            data: [
                @Model.TotalSeminaires,
                @Model.TotalParticipants,
                @Model.TotalInscriptions,
                @Model.TotalSpecialites
            ],
            backgroundColor: ['#1e3a8a','#10b981','#8b5cf6','#f59e0b']
        }]
    },
    options:{
        plugins:{legend:{display:false}},
        responsive:true
    }
});

new Chart(document.getElementById('lineChart'), {
    type: 'line',
    data: {
        labels: ['Jan','Feb','Mar','Apr','May','Jun'],
        datasets: [{
            label:'Activité',
            data:[5,10,8,15,20,@Model.TotalSeminaires],
            borderColor:'#1e3a8a',
            backgroundColor:'rgba(30,58,138,0.1)',
            fill:true,
            tension:0.4
        }]
    },
    options:{
        plugins:{legend:{display:false}},
        responsive:true
    }
});

</script>