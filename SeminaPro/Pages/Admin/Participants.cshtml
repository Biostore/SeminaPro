@page
@model SeminaPro.Pages.Admin.ParticipantsModel
@{
    ViewData["Title"] = "Participants";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">

<div class="page">

    <!-- HEADER -->
    <div class="header">
        <h1>Participants</h1>
        <p>Gestion des participants</p>
    </div>

    <div class="layout">

        <!-- FORM -->
        <div class="panel">

            <div class="panel-title">
                @(Model.Participant?.Id == 0 ? "Ajouter participant" : "Modifier participant")
            </div>

            <form method="post" asp-page-handler="Save">

                <input type="hidden" asp-for="Participant.Id" />

                <label>Nom</label>
                <input asp-for="Participant.Nom" />

                <label>Prénom</label>
                <input asp-for="Participant.Prenom" />

                <label>Email</label>
                <input asp-for="Participant.Email" type="email" />

                <label>Téléphone</label>
                <input asp-for="Participant.NumeroTelephone" />

                <label>Spécialité</label>
                <select asp-for="Participant.SpecialiteId"
                        asp-items="@(new SelectList(Model.Specialites, "Id", "Libelle"))">
                    <option value="">Sélectionner</option>
                </select>

                <button type="submit">
                    Enregistrer
                </button>

            </form>

        </div>

        <!-- LIST -->
        <div class="panel">

            <div class="panel-title-row">
                <span>Liste des participants</span>
                <span class="count">@((Model.Participants?.Count) ?? 0)</span>
            </div>

            @if (Model.Participants != null && Model.Participants.Any())
            {
                <table>

                    <thead>
                        <tr>
                            <th>Nom</th>
                            <th>Email</th>
                            <th>Spécialité</th>
                            <th></th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var p in Model.Participants)
                        {
                            <tr>

                                <td class="name">@p.Nom @p.Prenom</td>

                                <td class="muted">@p.Email</td>

                                <td>
                                    <span class="tag">@p.Specialite?.Libelle</span>
                                </td>

                                <td class="actions">

                                    <a href="?id=@p.Id" class="icon edit">
                                        <i class="bi bi-pencil"></i>
                                    </a>

                                    <form method="post"
                                          asp-page-handler="Delete"
                                          asp-route-id="@p.Id"
                                          onsubmit="return confirm('Supprimer ?')">

                                        <button class="icon delete">
                                            <i class="bi bi-trash"></i>
                                        </button>

                                    </form>

                                </td>

                            </tr>
                        }
                    </tbody>

                </table>
            }
            else
            {
                <div class="empty">Aucun participant</div>
            }

        </div>

    </div>

</div>

<style>

    /* GLOBAL */
    .page {
        padding: 32px;
        font-family: system-ui;
        color: #0f172a;
        background: #f8fafc;
    }

    /* HEADER */
    .header h1 {
        font-size: 24px;
        font-weight: 800;
        color: #1e3a8a;
        margin-bottom: 4px;
    }

    .header p {
        color: #64748b;
        font-size: 13px;
    }

    /* LAYOUT */
    .layout {
        display: grid;
        grid-template-columns: 340px 1fr;
        gap: 22px;
        margin-top: 20px;
    }

    /* PANEL */
    .panel {
        border: 1px solid #e2e8f0;
        border-radius: 14px;
        padding: 18px;
        background: white;
        box-shadow: 0 6px 18px rgba(30, 58, 138, 0.06);
        transition: 0.3s ease;
    }

        .panel:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 25px rgba(30, 58, 138, 0.10);
        }

    /* TITLES */
    .panel-title {
        font-weight: 700;
        font-size: 14px;
        color: #1e3a8a;
        margin-bottom: 12px;
    }

    .panel-title-row {
        display: flex;
        justify-content: space-between;
        font-weight: 700;
        font-size: 13px;
        color: #1e3a8a;
        margin-bottom: 10px;
    }

    /* COUNT */
    .count {
        font-size: 11px;
        background: #e0e7ff;
        color: #1e3a8a;
        padding: 3px 10px;
        border-radius: 999px;
        font-weight: 600;
    }

    /* FORM */
    label {
        display: block;
        font-size: 12px;
        color: #475569;
        margin-top: 10px;
    }

    input, select {
        width: 100%;
        padding: 10px;
        margin-top: 6px;
        border: 1px solid #cbd5e1;
        border-radius: 10px;
        font-size: 13px;
        transition: 0.2s;
        background: #f8fafc;
    }

        input:focus, select:focus {
            border-color: #2563eb;
            box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.15);
            background: white;
        }

    /* BUTTON */
    button {
        margin-top: 14px;
        width: 100%;
        padding: 11px;
        border-radius: 10px;
        border: none;
        background: linear-gradient(135deg, #1e3a8a, #2563eb);
        color: white;
        cursor: pointer;
        font-size: 13px;
        font-weight: 600;
        transition: 0.3s;
    }

        button:hover {
            transform: translateY(-1px);
            opacity: 0.95;
        }

    /* TABLE */
    table {
        width: 100%;
        border-collapse: collapse;
    }

    th {
        text-align: left;
        font-size: 11px;
        color: #64748b;
        border-bottom: 1px solid #e2e8f0;
        padding: 10px 0;
        text-transform: uppercase;
    }

    td {
        padding: 13px 0;
        border-bottom: 1px solid #f1f5f9;
    }

    /* TEXT */
    .name {
        font-weight: 600;
        color: #0f172a;
    }

    .muted {
        color: #64748b;
        font-size: 12px;
    }

    /* TAG */
    .tag {
        font-size: 11px;
        background: #e0e7ff;
        color: #1e3a8a;
        padding: 4px 10px;
        border-radius: 999px;
    }

    /* ACTIONS */
    .actions {
        display: flex;
        justify-content: flex-end;
        gap: 8px;
    }

    /* ICON BUTTON */
    .icon {
        border: 1px solid #e2e8f0;
        background: white;
        padding: 6px 8px;
        border-radius: 8px;
        cursor: pointer;
        transition: 0.2s;
    }

        .icon:hover {
            border-color: #2563eb;
            background: #eff6ff;
        }

    .delete {
        color: #dc2626;
    }

    /* EMPTY */
    .empty {
        padding: 25px;
        text-align: center;
        color: #94a3b8;
        font-size: 13px;
    }

    /* RESPONSIVE */
    @@media (max-width: 900px) {
        .layout {
            grid-template-columns: 1fr;
        }
    }

</style>