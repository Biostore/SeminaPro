@page
@using SeminaPro.Pages.Account
@model LogoutModel

@{
    Layout = null;
    ViewData["Title"] = "Déconnexion";
}

<!DOCTYPE html>
<html lang="fr">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>@ViewData["Title"] - SeminaPro</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

    <!-- Bootstrap Icons -->
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <style>

            * {
                margin: 0;
                padding: 0;
                box-sizing: border-box;
            }

            body {
                min-height: 100vh;
                font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
                background: linear-gradient(135deg, #163b73, #2f5fa7, #4b7fd1);
                display: flex;
                justify-content: center;
                align-items: center;
                padding: 20px;
            }

            .logout-container {
                width: 100%;
                max-width: 500px;
            }

            .logout-card {
                background: rgba(255,255,255,0.98);
                border-radius: 24px;
                overflow: hidden;
                box-shadow: 0 20px 45px rgba(0,0,0,0.35);
                animation: fadeIn 0.8s ease;
                text-align: center;
            }

            /* HEADER */

            .logout-header {
                background: linear-gradient(135deg, #000814, #001d3d);
                color: white;
                padding: 45px 25px;
                position: relative;
            }

                .logout-header::after {
                    content: "";
                    position: absolute;
                    bottom: -40px;
                    left: 0;
                    width: 100%;
                    height: 80px;
                    background: white;
                    border-radius: 50%;
                }

            .success-circle {
                width: 100px;
                height: 100px;
                border-radius: 50%;
                margin: auto;
                background: rgba(255,255,255,0.12);
                border: 1px solid rgba(255,255,255,0.15);
                display: flex;
                justify-content: center;
                align-items: center;
                margin-bottom: 20px;
            }

                .success-circle i {
                    font-size: 50px;
                    color: #4ade80;
                }

            .logout-header h2 {
                font-weight: 700;
                margin-bottom: 8px;
            }

            .logout-header p {
                opacity: 0.85;
                margin: 0;
            }

            /* BODY */

            .logout-body {
                padding: 70px 35px 35px;
            }

                .logout-body h3 {
                    color: #001d3d;
                    font-weight: 700;
                    margin-bottom: 12px;
                }

                .logout-body p {
                    color: #666;
                    font-size: 16px;
                    margin-bottom: 30px;
                }

            /* BUTTON */

            .btn-home {
                display: inline-flex;
                align-items: center;
                justify-content: center;
                gap: 10px;
                width: 100%;
                height: 54px;
                border: none;
                border-radius: 14px;
                background: linear-gradient(135deg, #001d3d, #000814);
                color: white;
                font-weight: 700;
                font-size: 16px;
                text-decoration: none;
                transition: 0.3s;
            }

                .btn-home:hover {
                    background: linear-gradient(135deg, #000814, #001d3d);
                    transform: translateY(-2px);
                    box-shadow: 0 10px 20px rgba(0,0,0,0.35);
                    color: white;
                }

            /* ANIMATION */

            @@keyframes fadeIn {

                from {
                    opacity: 0;
                    transform: translateY(25px);
                }

                to {
                    opacity: 1;
                    transform: translateY(0);
                }
            }

            /* RESPONSIVE */

            @@media(max-width: 576px) {

                .logout-body {
                    padding: 65px 22px 25px;
                }

                .success-circle {
                    width: 80px;
                    height: 80px;
                }

                    .success-circle i {
                        font-size: 40px;
                    }
            }

    </style>

</head>

<body>

    <div class="logout-container">

        <div class="logout-card">

            <!-- HEADER -->

            <div class="logout-header">

                <div class="success-circle">

                    <i class="bi bi-check-circle-fill"></i>

                </div>

                <h2>Déconnexion</h2>

                <p>Votre session a été fermée</p>

            </div>

            <!-- BODY -->

            <div class="logout-body">

                <h3>Déconnexion réussie</h3>

                <p>

                    Vous avez été déconnecté avec succès de votre compte SeminaPro.

                </p>

                <a href="/" class="btn-home">

                    <i class="bi bi-house-door-fill"></i>

                    Retour à l'accueil

                </a>

            </div>

        </div>

    </div>

</body>

</html>