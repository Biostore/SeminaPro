@page
@using SeminaPro.Pages.Account
@model LogoutModel
@{
    ViewData["Title"] = "Déconnexion";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-body text-center py-5">
                    <i class="bi bi-check-circle text-success" style="font-size: 3rem;"></i>
                    <h3 class="card-title mt-3">Déconnexion réussie</h3>
                    <p class="text-muted">Vous avez été déconnecté avec succès.</p>
                    <a href="/" class="btn btn-primary mt-3">Retour à l'accueil</a>
                </div>
            </div>
        </div>
    </div>
</div>
