@page
@model SeminaPro.Pages.Account.RegisterModel
@using Microsoft.AspNetCore.Mvc.Rendering

@{
    Layout = null;
    ViewData["Title"] = "Inscription";
}

<!DOCTYPE html>
<html lang="fr">

<head>

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>Inscription - SeminaPro</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

    <!-- Bootstrap Icons -->
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <style>

            * {
                margin: 0;
                padding: 0;
                box-sizing: border-box;
            }

            body {
                min-height: 100vh;
                font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
                background: linear-gradient(135deg, #020617, #0f172a, #1e3a8a, #2563eb);
                display: flex;
                justify-content: center;
                align-items: center;
                padding: 40px 15px;
            }

            .register-container {
                width: 100%;
                max-width: 950px;
            }

            .register-card {
                background: rgba(255,255,255,0.98);
                border-radius: 28px;
                overflow: hidden;
                box-shadow: 0 25px 60px rgba(0,0,0,0.45);
                animation: fadeIn 0.8s ease;
            }

            /* HEADER */

            .register-header {
                background: linear-gradient(135deg, #020617, #0f172a);
                color: white;
                text-align: center;
                padding: 45px 25px;
                position: relative;
            }

                .register-header::after {
                    content: "";
                    position: absolute;
                    bottom: -45px;
                    left: 0;
                    width: 100%;
                    height: 90px;
                    background: white;
                    border-radius: 50%;
                }

            .logo-circle {
                width: 95px;
                height: 95px;
                margin: auto;
                border-radius: 50%;
                background: rgba(255,255,255,0.12);
                border: 1px solid rgba(255,255,255,0.15);
                display: flex;
                justify-content: center;
                align-items: center;
                margin-bottom: 20px;
            }

                .logo-circle i {
                    font-size: 42px;
                }

            .register-header h2 {
                font-weight: 800;
                margin-bottom: 8px;
            }

            .register-header p {
                opacity: 0.85;
                margin: 0;
            }

            /* BODY */

            .register-body {
                padding: 65px 35px 35px;
            }

            .form-label {
                font-weight: 600;
                color: #0f172a;
                margin-bottom: 8px;
            }

            .input-group {
                margin-bottom: 22px;
            }

            .input-group-text {
                background: #eff6ff;
                border: 1px solid #dbe4ee;
                border-right: none;
                border-radius: 12px 0 0 12px;
                color: #1e3a8a;
            }

            .form-control,
            .form-select {
                height: 52px;
                border: 1px solid #dbe4ee;
                background: #f8fafc;
                transition: 0.3s;
            }

            .form-control {
                border-left: none;
                border-radius: 0 12px 12px 0;
            }

            .form-select {
                border-radius: 12px;
            }

                .form-control:focus,
                .form-select:focus {
                    border-color: #2563eb;
                    box-shadow: 0 0 0 4px rgba(37,99,235,0.15);
                    background: white;
                }

            /* DYNAMIC BOX */

            .dynamic-box {
                background: #f8fafc;
                border: 1px solid #dbe4ee;
                border-radius: 18px;
                padding: 22px;
                margin-bottom: 22px;
            }

            /* CHECKBOX */

            .form-check-input:checked {
                background-color: #1e3a8a;
                border-color: #1e3a8a;
            }

            /* BUTTON */

            .btn-register {
                width: 100%;
                height: 56px;
                border: none;
                border-radius: 16px;
                background: linear-gradient(135deg, #1e3a8a, #2563eb);
                color: white;
                font-weight: 700;
                font-size: 16px;
                transition: 0.3s;
                margin-top: 12px;
            }

                .btn-register:hover {
                    transform: translateY(-2px);
                    box-shadow: 0 12px 25px rgba(37,99,235,0.35);
                }

            /* LOGIN LINK */

            .login-link {
                text-align: center;
                margin-top: 28px;
                color: #64748b;
            }

                .login-link a {
                    color: #1e3a8a;
                    font-weight: 700;
                    text-decoration: none;
                }

                    .login-link a:hover {
                        text-decoration: underline;
                    }

            /* ALERT */

            .alert {
                border-radius: 14px;
            }

            /* ANIMATION */

            @@keyframes fadeIn {

                from {
                    opacity: 0;
                    transform: translateY(25px);
                }

                to {
                    opacity: 1;
                    transform: translateY(0);
                }
            }

            /* RESPONSIVE */

            @@media(max-width: 768px) {

                .register-body {
                    padding: 55px 20px 25px;
                }

                .logo-circle {
                    width: 75px;
                    height: 75px;
                }
            }

    </style>

</head>

<body>

    <div class="register-container">

        <div class="register-card">

            <!-- HEADER -->

            <div class="register-header">

                <div class="logo-circle">

                    <i class="bi bi-person-plus-fill"></i>

                </div>

                <h2>Créer un compte</h2>

                <p>Rejoignez SeminaPro</p>

            </div>

            <!-- BODY -->

            <div class="register-body">

                @if (!string.IsNullOrEmpty(Model.Message))
                {
                    <div class="alert alert-success">
                        @Model.Message
                    </div>
                }

                @if (!string.IsNullOrEmpty(Model.Error))
                {
                    <div class="alert alert-danger">
                        @Model.Error
                    </div>
                }

                <form method="post">

                    <!-- NAMES -->

                    <div class="row">

                        <div class="col-md-6">

                            <label class="form-label">Prénom</label>

                            <div class="input-group">

                                <span class="input-group-text">
                                    <i class="bi bi-person-fill"></i>
                                </span>

                                <input asp-for="FirstName"
                                       class="form-control"
                                       required>

                            </div>

                        </div>

                        <div class="col-md-6">

                            <label class="form-label">Nom</label>

                            <div class="input-group">

                                <span class="input-group-text">
                                    <i class="bi bi-person-fill"></i>
                                </span>

                                <input asp-for="LastName"
                                       class="form-control"
                                       required>

                            </div>

                        </div>

                    </div>

                    <!-- EMAIL -->

                    <label class="form-label">Email</label>

                    <div class="input-group">

                        <span class="input-group-text">
                            <i class="bi bi-envelope-fill"></i>
                        </span>

                        <input asp-for="Email"
                               type="email"
                               class="form-control"
                               required>

                    </div>

                    <!-- PHONE -->

                    <label class="form-label">Téléphone</label>

                    <div class="input-group">

                        <span class="input-group-text">
                            <i class="bi bi-telephone-fill"></i>
                        </span>

                        <input asp-for="Phone"
                               class="form-control">

                    </div>

                    <!-- PASSWORDS -->

                    <div class="row">

                        <div class="col-md-6">

                            <label class="form-label">Mot de passe</label>

                            <div class="input-group">

                                <span class="input-group-text">
                                    <i class="bi bi-lock-fill"></i>
                                </span>

                                <input asp-for="Password"
                                       type="password"
                                       class="form-control"
                                       required>

                            </div>

                        </div>

                        <div class="col-md-6">

                            <label class="form-label">Confirmer</label>

                            <div class="input-group">

                                <span class="input-group-text">
                                    <i class="bi bi-shield-lock-fill"></i>
                                </span>

                                <input asp-for="ConfirmPassword"
                                       type="password"
                                       class="form-control"
                                       required>

                            </div>

                        </div>

                    </div>

                    <!-- SPECIALITE -->

                    <label class="form-label">Spécialité</label>

                    <select asp-for="SpecialiteId"
                            asp-items="@(new SelectList(Model.Specialites, "Id", "Libelle"))"
                            class="form-select mb-4"
                            required>

                        <option value="">-- Sélectionner une spécialité --</option>

                    </select>

                    <!-- ACCEPT -->

                    <div class="form-check mb-3">

                        <input asp-for="Accept"
                               class="form-check-input">

                        <label class="form-check-label">

                            J'accepte les conditions d'utilisation

                        </label>

                    </div>

                    <!-- BUTTON -->

                    <button type="submit" class="btn-register">

                        <i class="bi bi-check-circle-fill"></i>

                        S'INSCRIRE

                    </button>

                </form>

                <!-- LOGIN -->

                <div class="login-link">

                    Vous avez déjà un compte ?
                    <a href="/Account/Login">

                        Se connecter ici

                    </a>

                </div>

            </div>

        </div>

    </div>

    </body>
    </html>