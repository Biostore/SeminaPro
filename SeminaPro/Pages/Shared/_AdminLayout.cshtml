@using Microsoft.AspNetCore.Http
@inject SeminaPro.Data.ApplicationDbContext DbContext

@{
    var userEmail = Context.Session.GetString("UserEmail");
    var userRole = Context.Session.GetString("UserRole");

    string defaultImage = Url.Content("~/images/default-profile.png");
    string userImageUrl = defaultImage;
    string userName = "Admin";

    if (!string.IsNullOrEmpty(userEmail))
    {
        var user = DbContext.Participants
            .FirstOrDefault(p => p.Email == userEmail);

        if (user != null)
        {
            userName = $"{user.Prenom} {user.Nom}";

            if (!string.IsNullOrEmpty(user.ImageUrl))
            {
                userImageUrl = user.ImageUrl.StartsWith("http")
                    ? user.ImageUrl
                    : Url.Content(user.ImageUrl);
            }
        }
    }
}

<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SeminaPro Admin</title>

    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/admin-modern-design.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/admin-tables.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/admin-dashboard.css" asp-append-version="true" />
</head>

<body>

    <header>
        <nav class="navbar navbar-expand-lg navbar-dark sticky-top navbar-modern">
            <div class="container-lg">

                <a class="navbar-brand" href="/">
                    <img src="~/images/logo semina.png" height="70" />
                </a>

                <div class="navbar-collapse collapse">

                    <div class="d-flex align-items-center ms-auto gap-2">

                        @if (!string.IsNullOrEmpty(userEmail))
                        {
                            <span class="text-white small">
                                @(userRole == "Admin" ? "👨‍💼 Admin" : "👤 User")
                            </span>

                            <a href="/Account/Logout" class="btn btn-sm btn-danger">
                                <i class="bi bi-box-arrow-right"></i>
                            </a>
                        }
                        else
                        {
                            <a href="/Account/Login" class="btn btn-sm btn-primary">
                                Login
                            </a>
                        }

                    </div>

                </div>

            </div>
        </nav>
    </header>

    <div class="dashboard-container">

        <aside class="sidebar">

            <div class="admin-avatar-section">

                <div class="admin-avatar">
                    <img src="@userImageUrl"
                         class="admin-avatar-img"
                         onerror="this.src='@defaultImage'" />
                </div>

                <div class="admin-name">@userName</div>
                <div class="admin-role">Administrateur</div>

            </div>

            <hr />

            <a href="/Admin/Dashboard" class="sidebar-item">
                <i class="bi bi-speedometer2"></i> Dashboard
            </a>

            <a href="/Admin/Seminaires" class="sidebar-item">
                <i class="bi bi-book"></i> Séminaires
            </a>

            <a href="/Admin/Participants" class="sidebar-item">
                <i class="bi bi-people"></i> Participants
            </a>

            <a href="/Admin/Inscriptions" class="sidebar-item">
                <i class="bi bi-person-check"></i> Inscriptions
            </a>

            <a href="/Admin/Specialites" class="sidebar-item">
                <i class="bi bi-tag"></i> Spécialités
            </a>

            <a href="/Admin/Profile" class="sidebar-item">
                <i class="bi bi-person-circle"></i> Profil
            </a>

            <hr />

            <a href="/Account/Logout" class="sidebar-item text-danger">
                <i class="bi bi-box-arrow-right"></i> Déconnexion
            </a>

        </aside>

        <main class="main-content">
            @RenderBody()
        </main>

    </div>

    <footer class="text-center py-3 text-muted">
        © 2025 SeminaPro
    </footer>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("Scripts", required: false)

</body>
</html>