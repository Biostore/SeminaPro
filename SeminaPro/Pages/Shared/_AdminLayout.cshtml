@using Microsoft.AspNetCore.Http
@{
    var userEmail = Context.Session.GetString("UserEmail");
    var userRole = Context.Session.GetString("UserRole");
}
<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SeminaPro Admin</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/admin-modern-design.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/admin-tables.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/admin-dashboard.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark sticky-top navbar-modern">
            <div class="container-lg">
                <a class="navbar-brand" href="/">
                    <img src="/images/logo semina.png" alt="SeminaPro Logo" height="80" class="d-inline-block align-text-top logo-img">
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse">
                    <ul class="navbar-nav ms-auto flex-nowrap">
                        <li class="nav-item">
                            <a class="nav-link" href="/">Accueil</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/Seminaires/Index">Séminaires</a>
                        </li>
                    </ul>
                    <div class="d-flex align-items-center ms-3 gap-2">
                        @if (!string.IsNullOrEmpty(userEmail))
                        {
                            <span class="text-white me-2">
                                <small>Connecté : <strong>@(userRole == "Admin" ? "👨‍💼 Admin" : "👤 Participant")</strong></small>
                            </span>
                            <a href="/Account/Logout" class="btn btn-sm btn-outline-light">
                                <i class="bi bi-box-arrow-right"></i> Déconnexion
                            </a>
                        }
                        else
                        {
                            <a href="/Account/Login" class="btn btn-sm btn-login">Connexion</a>
                        }
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <div class="dashboard-container" id="admin-dashboard">
        <!-- SIDEBAR (persistante) -->
        <aside class="sidebar">
            <h5 class="fw-bold mb-4">🔧 Admin Menu</h5>
            <a href="/Admin/Dashboard" class="sidebar-item" data-path="/Admin/Dashboard">
                <i class="bi bi-speedometer2"></i>
                <span>Tableau de Bord</span>
            </a>
            <a href="/Admin/Seminaires" class="sidebar-item" data-path="/Admin/Seminaires">
                <i class="bi bi-book"></i>
                <span>Gérer Séminaires</span>
            </a>
            <a href="/Admin/Participants" class="sidebar-item" data-path="/Admin/Participants">
                <i class="bi bi-people"></i>
                <span>Gérer Participants</span>
            </a>
            <a href="/Admin/Inscriptions" class="sidebar-item" data-path="/Admin/Inscriptions">
                <i class="bi bi-person-check"></i>
                <span>Gérer Inscriptions</span>
            </a>
            <a href="/Admin/Specialites" class="sidebar-item" data-path="/Admin/Specialites">
                <i class="bi bi-tag"></i>
                <span>Gérer Spécialités</span>
            </a>

            <hr>

            <a href="/Admin/Settings" class="sidebar-item" data-path="/Admin/Settings">
                <i class="bi bi-gear-fill"></i>
                <span>Paramètres</span>
            </a>
            <a href="/Admin/Profile" class="sidebar-item" data-path="/Admin/Profile">
                <i class="bi bi-person-circle"></i>
                <span>Profil Admin</span>
            </a>

            <a href="/" class="sidebar-item mt-3">
                <i class="bi bi-house"></i>
                <span>Accueil</span>
            </a>
            <a href="/Account/Logout" class="sidebar-item" style="color: #ff3b30;">
                <i class="bi bi-box-arrow-right"></i>
                <span>Déconnexion</span>
            </a>
        </aside>

        <!-- MAIN CONTENT (sera mis à jour via AJAX) -->
        <div class="main-content">
            <div class="content-area" id="main-content">
                @RenderBody()
            </div>
        </div>
    </div>

    <footer class="footer-modern mt-auto">
        <div class="container-lg py-4">
            <div class="text-center small text-muted">&copy; 2025 SeminaPro</div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/admin-navigation.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>