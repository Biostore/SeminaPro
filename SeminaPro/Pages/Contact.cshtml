@page
@model ContactModel
@{
    ViewData["Title"] = "Contact - SeminaPro";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<style>
    body {
        margin: 0;
        background: #f8fafc;
        font-family: "Segoe UI", sans-serif;
        color: #0f172a;
    }

    /* 🔵 TOP BAR BLEUE */
    .topbar {
        width: 100%;
        background: #3b82f6;
        color: white;
        padding: 10px 20px;
        font-size: 13px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        position: fixed;
        top: 0;
        left: 0;
        z-index: 1000;
    }

        .topbar .left {
            display: flex;
            align-items: center;
            gap: 8px;
            font-weight: 600;
        }

        .topbar .right {
            font-size: 12px;
            opacity: 0.9;
        }

    /* PAGE */
    .page {
        width: 100%;
        max-width: 1200px;
        margin: auto;
        padding: 80px 20px 30px; /* 🔥 padding-top pour topbar */
    }

    /* HEADER */
    .header {
        margin-bottom: 18px;
    }

        .header h1 {
            font-size: 26px;
            font-weight: 700;
            margin: 0;
        }

        .header p {
            color: #64748b;
            font-size: 13px;
            margin: 4px 0 0;
        }

    /* GRID */
    .grid {
        display: grid;
        grid-template-columns: 1fr 1.4fr;
        gap: 16px;
        align-items: stretch;
    }

    @@media (max-width: 900px) {
        .grid {
            grid-template-columns: 1fr;
        }
    }

    /* CARD */
    .card {
        background: white;
        border: 1px solid #e2e8f0;
        border-radius: 12px;
        padding: 18px;
    }

    /* INFO */
    .info-item {
        display: flex;
        gap: 12px;
        padding: 12px 0;
        border-bottom: 1px solid #f1f5f9;
    }

        .info-item:last-child {
            border-bottom: none;
        }

    .icon {
        width: 38px;
        height: 38px;
        background: #f1f5f9;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #3b82f6;
        font-size: 15px;
        flex-shrink: 0;
    }

    /* FORM */
    .form-control {
        width: 100%;
        padding: 11px;
        border-radius: 10px;
        border: 1px solid #e2e8f0;
        font-size: 14px;
        margin-bottom: 10px;
    }

        .form-control:focus {
            outline: none;
            border-color: #3b82f6;
            box-shadow: 0 0 0 3px rgba(59,130,246,0.15);
        }

    /* BUTTON */
    .btn {
        background: #3b82f6;
        color: white;
        padding: 10px 16px;
        border-radius: 10px;
        border: none;
        font-weight: 600;
        cursor: pointer;
    }

        .btn:hover {
            background: #2563eb;
        }

    .btn-wrapper {
        display: flex;
        justify-content: flex-end;
    }

    /* FAQ */
    .faq {
        margin-top: 20px;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
    }

    @@media (max-width: 900px) {
        .faq {
            grid-template-columns: 1fr;
        }
    }

    .faq-item {
        background: white;
        border: 1px solid #e2e8f0;
        padding: 14px;
        border-radius: 12px;
    }

        .faq-item h4 {
            font-size: 14px;
            margin: 0;
            font-weight: 600;
        }

        .faq-item p {
            font-size: 13px;
            color: #64748b;
            margin-top: 5px;
        }

    /* MAP */
    .map {
        margin-top: 18px;
        border-radius: 12px;
        overflow: hidden;
        border: 1px solid #e2e8f0;
    }

</style>

<!-- 🔵 TOPBAR -->
<div class="topbar">
    <div class="left">
        <i class="bi bi-lightning-charge-fill"></i>
        SeminaPro
    </div>

    <div class="right">
        Support actif • Contact 24/7
    </div>
</div>

<div class="page">

    <!-- HEADER -->
    <div class="header">
        <h1>Contact</h1>
        <p>Nous sommes disponibles pour répondre à toutes vos questions</p>
    </div>

    <!-- MAIN GRID -->
    <div class="grid">

        <!-- LEFT -->
        <div class="card">

            <div class="info-item">
                <div class="icon"><i class="bi bi-geo-alt"></i></div>
                <div>
                    <strong>Adresse</strong><br />
                    <span style="color:#64748b;font-size:13px;">Paris, France</span>
                </div>
            </div>

            <div class="info-item">
                <div class="icon"><i class="bi bi-telephone"></i></div>
                <div>
                    <strong>Téléphone</strong><br />
                    <span style="color:#64748b;font-size:13px;">+33 12 34 56 78</span>
                </div>
            </div>

            <div class="info-item">
                <div class="icon"><i class="bi bi-envelope"></i></div>
                <div>
                    <strong>Email</strong><br />
                    <span style="color:#64748b;font-size:13px;">info@seminapro.com</span>
                </div>
            </div>

        </div>

        <!-- RIGHT -->
        <div class="card">

            <form method="post">

                <input class="form-control" name="FirstName" placeholder="Prénom" />
                <input class="form-control" name="LastName" placeholder="Nom" />
                <input class="form-control" name="Email" type="email" placeholder="Email" />
                <textarea class="form-control" name="Message" rows="5" placeholder="Message..."></textarea>

                <div class="btn-wrapper">
                    <button class="btn">Envoyer</button>
                </div>

            </form>

        </div>

    </div>

    <!-- FAQ -->
    <div class="faq">

        <div class="faq-item">
            <h4>Délai de réponse</h4>
            <p>Nous répondons sous 24 heures.</p>
        </div>

        <div class="faq-item">
            <h4>Support</h4>
            <p>Disponible du lundi au vendredi.</p>
        </div>

    </div>

    <!-- MAP -->
    <div class="map">
        <iframe width="100%" height="350"
                src="https://www.google.com/maps/embed?pb=!1m18..."
                style="border:0;"></iframe>
    </div>

</div>