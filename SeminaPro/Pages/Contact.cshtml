@page
@model ContactModel
@{
    ViewData["Title"] = "Contact - SeminaPro";
}

<div class="contact-container">
    <!-- Hero Section -->
    <section class="contact-hero">
        <div class="container-lg py-5">
            <h1 class="contact-title">Nous Contacter</h1>
            <p class="contact-subtitle">Vous avez des questions ? Nous sommes là pour vous aider !</p>
        </div>
    </section>

    <div class="container-lg py-5">
        <div class="row g-4">
            <!-- Contact Information Cards -->
            <div class="col-lg-5">
                <div class="contact-info-section">
                    <h2 class="mb-4">Coordonnées</h2>

                    <!-- Address Card -->
                    <div class="contact-card">
                        <div class="contact-card-icon">
                            <i class="bi bi-geo-alt"></i>
                        </div>
                        <div class="contact-card-content">
                            <h3>Adresse</h3>
                            <p>
                                123 Avenue Principale<br>
                                75000 Paris, France
                            </p>
                        </div>
                    </div>

                    <!-- Phone Card -->
                    <div class="contact-card">
                        <div class="contact-card-icon">
                            <i class="bi bi-telephone"></i>
                        </div>
                        <div class="contact-card-content">
                            <h3>Téléphone</h3>
                            <p>
                                <a href="tel:+33123456789">+33 (1) 23 45 67 89</a><br>
                                <small>Lun - Ven, 9h00 - 18h00</small>
                            </p>
                        </div>
                    </div>

                    <!-- Email Card -->
                    <div class="contact-card">
                        <div class="contact-card-icon">
                            <i class="bi bi-envelope"></i>
                        </div>
                        <div class="contact-card-content">
                            <h3>Email</h3>
                            <p>
                                <a href="mailto:info@seminapro.com">info@seminapro.com</a><br>
                                <a href="mailto:support@seminapro.com">support@seminapro.com</a>
                            </p>
                        </div>
                    </div>

                    <!-- Hours Card -->
                    <div class="contact-card">
                        <div class="contact-card-icon">
                            <i class="bi bi-clock"></i>
                        </div>
                        <div class="contact-card-content">
                            <h3>Heures d'Ouverture</h3>
                            <p>
                                Lundi - Vendredi: 9h00 - 18h00<br>
                                Samedi: 10h00 - 14h00<br>
                                Dimanche: Fermé
                            </p>
                        </div>
                    </div>

                    <!-- Social Links -->
                    <div class="social-links mt-4 pt-4 border-top">
                        <h3 class="mb-3">Suivez-Nous</h3>
                        <div class="d-flex gap-3">
                            <a href="#" class="social-icon" title="Facebook"><i class="bi bi-facebook"></i></a>
                            <a href="#" class="social-icon" title="Twitter"><i class="bi bi-twitter"></i></a>
                            <a href="#" class="social-icon" title="LinkedIn"><i class="bi bi-linkedin"></i></a>
                            <a href="#" class="social-icon" title="Instagram"><i class="bi bi-instagram"></i></a>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Contact Form -->
            <div class="col-lg-7">
                <div class="contact-form-section">
                    <h2 class="mb-4">Formulaire de Contact</h2>

                    @if (!string.IsNullOrEmpty(Model.Message))
                    {
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            <i class="bi bi-check-circle"></i> @Model.Message
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                    {
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            <i class="bi bi-exclamation-circle"></i> @Model.ErrorMessage
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }

                    <form method="post" class="contact-form">
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label for="firstName" class="form-label">Prénom *</label>
                                <input type="text" class="form-control" id="firstName" name="FirstName" 
                                       required placeholder="Votre prénom" value="@Model.FirstName">
                            </div>
                            <div class="col-md-6 mb-3">
                                <label for="lastName" class="form-label">Nom *</label>
                                <input type="text" class="form-control" id="lastName" name="LastName" 
                                       required placeholder="Votre nom" value="@Model.LastName">
                            </div>
                        </div>

                        <div class="mb-3">
                            <label for="email" class="form-label">Email *</label>
                            <input type="email" class="form-control" id="email" name="Email" 
                                   required placeholder="votre.email@exemple.com" value="@Model.Email">
                        </div>

                        <div class="mb-3">
                            <label for="phone" class="form-label">Téléphone</label>
                            <input type="tel" class="form-control" id="phone" name="Phone" 
                                   placeholder="+33 (1) 23 45 67 89" value="@Model.Phone">
                        </div>

                        <div class="mb-3">
                            <label for="subject" class="form-label">Sujet *</label>
                            <select class="form-control" id="subject" name="Subject" required>
                                <option value="">-- Sélectionnez un sujet --</option>
                                <option value="general">Question générale</option>
                                <option value="support">Support technique</option>
                                <option value="billing">Facturation</option>
                                <option value="partnership">Partenariat</option>
                                <option value="feedback">Retour / Suggestion</option>
                                <option value="other">Autre</option>
                            </select>
                        </div>

                        <div class="mb-3">
                            <label for="message" class="form-label">Message *</label>
                            <textarea class="form-control" id="message" name="Message" rows="6" 
                                      required placeholder="Écrivez votre message ici...">@Model.ContactMessage</textarea>
                        </div>

                        <div class="form-check mb-3">
                            <input class="form-check-input" type="checkbox" id="terms" name="Terms" required>
                            <label class="form-check-label" for="terms">
                                J'accepte les <a href="#">conditions d'utilisation</a> et la 
                                <a href="#">politique de confidentialité</a>
                            </label>
                        </div>

                        <button type="submit" class="btn btn-primary btn-lg w-100">
                            <i class="bi bi-send"></i> Envoyer le Message
                        </button>
                    </form>

                    <p class="text-muted small mt-3">* Champs obligatoires</p>
                </div>
            </div>
        </div>

        <!-- Map Section -->
        <section class="map-section mt-5 pt-5 border-top">
            <h2 class="text-center mb-4">Localisation</h2>
            <div class="map-container">
                <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2624.9915256854155!2d2.3522!3d48.8566!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x47e66e1c4b4a1d7b%3A0x1d4a4f4e4e4e4e4e!2sParis%2C%20France!5e0!3m2!1sfr!2sfr!4v1234567890" 
                        width="100%" height="450" style="border:0;" allowfullscreen="" loading="lazy" 
                        referrerpolicy="no-referrer-when-downgrade"></iframe>
            </div>
        </section>
    </div>
</div>
