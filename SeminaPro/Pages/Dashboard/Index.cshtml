@page
@model SeminaPro.Pages.Dashboard.IndexModel
@{
    ViewData["Title"] = "Mon Tableau de Bord";
    Layout = "_DashboardLayout";
}

<div class="dashboard-container" id="participant-dashboard">
    <!-- NAVBAR -->
    <nav class="navbar navbar-expand-lg navbar-dark navbar-dashboard sticky-top">
        <div class="container-fluid px-4">
            <a class="navbar-brand" href="/">
                <img src="/images/logo semina.png" alt="SeminaPro Logo" height="40" class="d-inline-block align-text-top">
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto align-items-center gap-3">
                    <li class="nav-item">
                        <a class="nav-link" href="/">
                            <i class="bi bi-house"></i> Accueil
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/Seminaires/Index">
                            <i class="bi bi-book"></i> Séminaires
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/About">
                            <i class="bi bi-info-circle"></i> À Propos
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/Contact">
                            <i class="bi bi-envelope"></i> Contact
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/Dashboard/Index">
                            <i class="bi bi-speedometer2"></i> Mon Tableau
                        </a>
                    </li>
                    <li class="nav-item">
                        <span class="nav-text">Connecté: <strong>Participant</strong></span>
                    </li>
                    <li class="nav-item">
                        <a href="/Account/Logout" class="btn btn-outline-light btn-sm">
                            <i class="bi bi-box-arrow-right"></i> DÉCONNEXION
                        </a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- DASHBOARD CONTENT WRAPPER -->
    <div class="dashboard-content-wrapper">
        <!-- SIDEBAR AMÉLIORÉE -->
        <aside class="sidebar sidebar-modern">
            <div class="sidebar-header">
                <h5 class="fw-bold mb-0">👤 PARTICIPANT</h5>
            </div>

            <nav class="sidebar-nav">
                <a href="/Dashboard/Index" class="sidebar-item active" data-path="/Dashboard/Index">
                    <i class="bi bi-speedometer2"></i>
                    <span>Tableau de Bord</span>
                </a>
                <a href="#mes-seminaires" class="sidebar-item" onclick="document.getElementById('mes-seminaires').scrollIntoView({behavior:'smooth'})">
                    <i class="bi bi-book"></i>
                    <span>Mes Séminaires</span>
                </a>
                <a href="#mon-profil" class="sidebar-item" onclick="document.getElementById('mon-profil').scrollIntoView({behavior:'smooth'})">
                    <i class="bi bi-person-circle"></i>
                    <span>Mon Profil</span>
                </a>
                <a href="/Seminaires/Index" class="sidebar-item" data-path="/Seminaires/Index">
                    <i class="bi bi-search"></i>
                    <span>Parcourir</span>
                </a>
                <a href="/Dashboard/Settings" class="sidebar-item" data-path="/Dashboard/Settings">
                    <i class="bi bi-gear-fill"></i>
                    <span>Paramètres</span>
                </a>
                <a href="/" class="sidebar-item">
                    <i class="bi bi-house"></i>
                    <span>Accueil</span>
                </a>
                <a href="/Account/Logout" class="sidebar-item sidebar-item-danger">
                    <i class="bi bi-box-arrow-right"></i>
                    <span>Déconnexion</span>
                </a>
            </nav>
        </aside>

        <!-- MAIN CONTENT -->
        <div class="main-content">
            <div class="content-area">
                <!-- WELCOME HEADER -->
                <div class="welcome-header mb-5">
                    <h1><i class="bi bi-speedometer2"></i> Tableau de Bord Personnel</h1>
                    <p>Votre espace personnel — résumé rapide et actions</p>
                </div>

                <!-- STATISTIQUES CARDS -->
                <div class="row mb-4 g-4">
                    <div class="col-md-6 col-lg-3">
                        <div class="stat-card stat-card-primary" data-href="/Seminaires/Index" style="cursor: pointer;">
                            <div class="stat-icon">
                                <i class="bi bi-check-circle-fill"></i>
                            </div>
                            <div class="stat-content">
                                <h3>@Model.TotalInscriptions</h3>
                                <p>Inscriptions</p>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-6 col-lg-3">
                        <div class="stat-card stat-card-success" data-href="/Seminaires/Index?filter=upcoming" style="cursor: pointer;">
                            <div class="stat-icon">
                                <i class="bi bi-calendar-check-fill"></i>
                            </div>
                            <div class="stat-content">
                                <h3>@Model.InscriptionsAVenir</h3>
                                <p>À Venir</p>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-6 col-lg-3">
                        <div class="stat-card stat-card-info" data-href="/Seminaires/Index?filter=past" style="cursor: pointer;">
                            <div class="stat-icon">
                                <i class="bi bi-clock-history"></i>
                            </div>
                            <div class="stat-content">
                                <h3>@Model.InscriptionsPasses</h3>
                                <p>Passés</p>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-6 col-lg-3">
                        <div class="stat-card stat-card-warning" data-href="/Seminaires/Index" style="cursor: pointer;">
                            <div class="stat-icon">
                                <i class="bi bi-book-fill"></i>
                            </div>
                            <div class="stat-content">
                                <h3>@Model.TotalSeminairesDisponibles</h3>
                                <p>Disponibles</p>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- DEUX SECTIONS : CHART & ACTIVITÉS -->
                <div class="row mb-4">
                    <div class="col-lg-8">
                        <!-- CHART SECTION -->
                        <div class="card card-modern">
                            <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
                                <h5 class="mb-0"><i class="bi bi-graph-up"></i> Tendances et Répartition</h5>
                            </div>
                            <div class="card-body p-4">
                                <canvas id="inscriptionsChart" height="80" data-upcoming="@Model.InscriptionsAVenir" data-past="@Model.InscriptionsPasses" data-total="@Model.TotalInscriptions"></canvas>
                            </div>
                        </div>

                        <!-- CALENDRIER SECTION -->
                        <div class="card card-modern mt-4">
                            <div class="card-header bg-dark text-white">
                                <h5 class="mb-0"><i class="bi bi-calendar-event"></i> Calendrier</h5>
                            </div>
                            <div class="card-body p-4">
                                <div id="calendar" class="calendar-view">
                                    <div class="calendar-header d-flex justify-content-between align-items-center mb-3">
                                        <button class="btn btn-sm btn-outline-primary" id="prevMonth"><i class="bi bi-chevron-left"></i></button>
                                        <h6 class="mb-0" id="monthYear"></h6>
                                        <button class="btn btn-sm btn-outline-primary" id="nextMonth"><i class="bi bi-chevron-right"></i></button>
                                    </div>
                                    <div class="calendar-grid" id="calendarGrid"></div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- CÔTÉ DROIT: ACTIVITÉS & PROFIL -->
                    <div class="col-lg-4">
                        <!-- ACTIVITÉS RÉCENTES -->
                        <div class="card card-modern h-100">
                            <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
                                <h5 class="mb-0"><i class="bi bi-activity"></i> Activités Récentes</h5>
                                <a href="/Seminaires/Index" class="btn btn-sm btn-light">Voir tout</a>
                            </div>
                            <div class="card-body p-0">
                                <div class="recent-activities">
                                    @if (Model.MesInscriptions != null && Model.MesInscriptions.Count > 0)
                                    {
                                        foreach (var ins in Model.MesInscriptions.Take(5))
                                        {
                                            var isUpcoming = ins.Seminaire != null && ins.Seminaire.DateSeminaire > DateTime.Now;
                                            <div class="activity-item p-3">
                                                <div class="d-flex justify-content-between align-items-start gap-2">
                                                    <div class="flex-grow-1">
                                                        <div class="fw-600 text-dark">@ins.Seminaire?.Titre</div>
                                                        <div class="text-muted small mt-1">
                                                            <i class="bi bi-calendar-check me-1"></i>
                                                            @ins.Seminaire?.DateSeminaire.ToString("dd/MM/yyyy")
                                                        </div>
                                                    </div>
                                                    <span class="badge @(isUpcoming ? "bg-success" : "bg-secondary")">
                                                        @(isUpcoming ? "À venir" : "Passé")
                                                    </span>
                                                </div>
                                            </div>
                                        }
                                    }
                                    else
                                    {
                                        <div class="empty-state-box p-4 text-center">
                                            <div class="empty-icon mb-3">
                                                <i class="bi bi-inbox"></i>
                                            </div>
                                            <h6 class="text-muted mb-2">Aucune inscription</h6>
                                            <p class="small text-muted">Commencez en vous inscrivant à un séminaire</p>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- MES SÉMINAIRES SECTION -->
                <div id="mes-seminaires" class="row mb-4">
                    <div class="col-12">
                        <div class="card card-modern">
                            <div class="card-header bg-dark text-white">
                                <h5 class="mb-0"><i class="bi bi-calendar-range"></i> Mes Séminaires Inscrits</h5>
                            </div>
                            <div class="card-body p-0">
                                @if (Model.MesSeminaires != null && Model.MesSeminaires.Count > 0)
                                {
                                    <table class="table table-hover mb-0">
                                        <thead class="table-light">
                                            <tr>
                                                <th>Titre</th>
                                                <th>Date</th>
                                                <th>Lieu</th>
                                                <th>Code</th>
                                                <th class="text-center">Statut</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var seminaire in Model.MesSeminaires)
                                            {
                                                var isUpcoming = seminaire.DateSeminaire > DateTime.Now;
                                                <tr class="align-middle">
                                                    <td class="fw-600">@seminaire.Titre</td>
                                                    <td>
                                                        <small class="text-muted">
                                                            @seminaire.DateSeminaire.ToString("dd/MM/yyyy")
                                                        </small>
                                                    </td>
                                                    <td>@seminaire.Lieu</td>
                                                    <td>
                                                        <small class="text-muted">@(seminaire.Code)</small>
                                                    </td>
                                                    <td class="text-center">
                                                        <span class="badge @(isUpcoming ? "bg-success" : "bg-secondary")">
                                                            @(isUpcoming ? "À venir" : "Passé")
                                                        </span>
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                }
                                else
                                {
                                    <div class="empty-state-box p-5 text-center">
                                        <div class="empty-icon mb-3">
                                            <i class="bi bi-calendar"></i>
                                        </div>
                                        <h6 class="text-muted mb-2">Aucun séminaire inscrit</h6>
                                        <p class="small text-muted mb-3">Vous n'êtes inscrit à aucun séminaire pour le moment</p>
                                        <a href="/Seminaires/Index" class="btn btn-primary btn-sm">
                                            <i class="bi bi-search me-1"></i>Parcourir les séminaires
                                        </a>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>

                <!-- MON PROFIL SECTION -->
                <div id="mon-profil" class="row">
                    <div class="col-lg-8">
                        <div class="card card-modern">
                            <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
                                <h5 class="mb-0"><i class="bi bi-person-badge"></i> Mon Profil</h5>
                                <a href="#" class="btn btn-sm btn-light" title="Modifier">
                                    <i class="bi bi-pencil"></i> Modifier
                                </a>
                            </div>
                            <div class="card-body">
                                <div class="row">
                                    <div class="col-md-6 mb-3">
                                        <label class="text-muted small">Email</label>
                                        <div class="fw-600">@Model.UserEmail</div>
                                    </div>
                                    @if (Model.CurrentParticipant != null)
                                    {
                                        <div class="col-md-6 mb-3">
                                            <label class="text-muted small">Nom</label>
                                            <div class="fw-600">@(Model.CurrentParticipant.Nom ?? "Non spécifié")</div>
                                        </div>
                                        <div class="col-md-6 mb-3">
                                            <label class="text-muted small">Prénom</label>
                                            <div class="fw-600">@(Model.CurrentParticipant.Prenom ?? "Non spécifié")</div>
                                        </div>
                                        <div class="col-md-6 mb-3">
                                            <label class="text-muted small">Téléphone</label>
                                            <div class="fw-600">@(Model.CurrentParticipant.NumeroTelephone ?? "Non spécifié")</div>
                                        </div>
                                        <div class="col-md-6 mb-3">
                                            <label class="text-muted small">Type de Participant</label>
                                            <div class="fw-600">@(Model.CurrentParticipant.GetType().Name == "Universitaire" ? "Universitaire" : "Industriel")</div>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- PARAMÈTRES SECTION -->
                    <div class="col-lg-4">
                        <div class="card card-modern h-100">
                            <div class="card-header bg-dark text-white">
                                <h5 class="mb-0"><i class="bi bi-sliders"></i> Paramètres Rapides</h5>
                            </div>
                            <div class="card-body d-flex flex-column gap-2">
                                <a href="/Seminaires/Index" class="btn btn-primary btn-sm d-flex align-items-center gap-2">
                                    <i class="bi bi-search"></i> Parcourir Séminaires
                                </a>
                                <a href="#" class="btn btn-outline-primary btn-sm d-flex align-items-center gap-2">
                                    <i class="bi bi-gear-fill"></i> Modifier Profil
                                </a>
                                <a href="#" class="btn btn-outline-primary btn-sm d-flex align-items-center gap-2">
                                    <i class="bi bi-shield-lock"></i> Changer Mot de Passe
                                </a>
                                <a href="#" class="btn btn-outline-primary btn-sm d-flex align-items-center gap-2">
                                    <i class="bi bi-bell"></i> Notifications
                                </a>
                                <hr class="my-2">
                                <a href="/Account/Logout" class="btn btn-outline-danger btn-sm d-flex align-items-center gap-2">
                                    <i class="bi bi-box-arrow-right"></i> Déconnexion
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="~/js/dashboard-participant.js" asp-append-version="true"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            document.querySelectorAll('.stat-card[data-href]').forEach(function (el) { 
                el.addEventListener('click', function () { 
                    var href = el.getAttribute('data-href'); 
                    if (href) window.location.href = href; 
                }); 
            });

            var canvas = document.getElementById('inscriptionsChart');
            if (canvas) {
                var upcoming = parseInt(canvas.dataset.upcoming || '0');
                var past = parseInt(canvas.dataset.past || '0');
                var total = parseInt(canvas.dataset.total || '0');
                var other = Math.max(0, total - (upcoming + past));
                new Chart(canvas, {
                    type: 'doughnut',
                    data: { 
                        labels: ['À venir','Passés','Autres'], 
                        datasets: [{ 
                            data: [upcoming, past, other], 
                            backgroundColor: ['#22c55e','#3b82f6','#d1d5db'] 
                        }] 
                    },
                    options: { 
                        plugins: { legend: { position: 'bottom' } }, 
                        maintainAspectRatio: false 
                    }
                });
            }
        });
    </script>
    <script src="~/js/dashboard-calendar.js" asp-append-version="true"></script>
}
