@page
@model SeminaPro.Pages.Dashboard.SettingsModel
@{
    ViewData["Title"] = "Paramètres";
    Layout = "_DashboardLayout";
}

<style>
    :root {
        --navy: #0f172a;
        --sky: #0ea5e9;
        --green: #22c55e;
        --amber: #f59e0b;
        --red: #ef4444;
        --white: #ffffff;
        --r: 16px;
        --sh1: 0 2px 8px rgba(15,23,42,.07);
        --sh2: 0 8px 24px rgba(15,23,42,.11);
    }

    * { box-sizing: border-box; }

    html, body {
        margin: 0;
        padding: 0;
        font-family: 'DM Sans', sans-serif;
        background: #f1f5f9;
    }

    .dashboard-container {
        display: flex;
        min-height: 100vh;
        margin: 0;
        padding: 0;
    }

    .sidebar-modern {
        position: fixed;
        left: 0;
        top: 0;
        width: 240px;
        height: 100vh;
        background: var(--navy);
        overflow-y: auto;
        padding-top: 0;
        z-index: 99;
        box-shadow: 2px 0 8px rgba(0,0,0,.15);
    }

    .dashboard-content-wrapper {
        margin-left: 240px;
        width: calc(100% - 240px);
        display: flex;
        flex-direction: column;
        min-height: 100vh;
    }

    .navbar-dashboard {
        background: linear-gradient(135deg, #0c2040 0%, #0a3356 100%);
        box-shadow: 0 4px 12px rgba(0,0,0,.1);
        position: sticky;
        top: 0;
        z-index: 100;
        margin: 0;
        padding: 1rem;
    }

    .navbar-dashboard .container-fluid {
        max-width: 100%;
    }

    .main-content {
        flex: 1;
        background: #f1f5f9;
        overflow-y: auto;
    }

    .content-area {
        padding: 2rem;
        width: 100%;
    }

    /* SIDEBAR */
    .sidebar-header {
        padding: 1.2rem 1.2rem;
        border-bottom: 1px solid rgba(255,255,255,.1);
    }

    .sidebar-header h5 {
        color: #fff;
        margin: 0;
        font-size: 0.9rem;
    }

    .sidebar-nav {
        padding: 1rem 0.8rem;
    }

    .sidebar-item {
        display: flex;
        align-items: center;
        gap: 0.8rem;
        padding: 0.85rem 1rem;
        border-radius: 10px;
        color: #94a3b8;
        text-decoration: none;
        transition: all 0.2s;
        margin-bottom: 0.5rem;
        border-left: 3px solid transparent;
        font-size: 0.9rem;
    }

    .sidebar-item:hover {
        background: rgba(56,189,248,.12);
        color: #fff;
    }

    .sidebar-item.active {
        background: rgba(56,189,248,.12);
        color: #fff;
        border-left-color: var(--sky);
    }

    .sidebar-item-danger:hover {
        background: rgba(244,63,94,.15);
        color: #f43f5e;
    }

    /* SETTINGS PAGE */
    .settings-page {
        max-width: 100%;
        margin: 0;
        padding: 0;
    }

    /* HEADER */
    .settings-header {
        margin-bottom: 2rem;
        padding-bottom: 1.5rem;
        border-bottom: 2px solid #e2e8f0;
    }

    .settings-header h1 {
        font-size: 1.8rem;
        font-weight: 800;
        color: var(--navy);
        margin-bottom: 0.5rem;
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }

    .settings-header p {
        color: #64748b;
        font-size: 0.95rem;
        margin: 0;
    }

    /* ALERTS */
    .alert-success {
        background: #ecfdf5;
        border-left: 4px solid #10b981;
        color: #065f46;
        border-radius: var(--r);
        padding: 1rem;
        margin-bottom: 1.5rem;
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }

    .alert-danger {
        background: #fef2f2;
        border-left: 4px solid #ef4444;
        color: #7f1d1d;
        border-radius: var(--r);
        padding: 1rem;
        margin-bottom: 1.5rem;
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }

    /* CARD */
    .settings-section {
        background: var(--white);
        border-radius: var(--r);
        border: 1px solid #e2e8f0;
        margin-bottom: 1.5rem;
        box-shadow: var(--sh1);
        overflow: hidden;
        transition: box-shadow 0.2s;
    }

    .settings-section:hover {
        box-shadow: var(--sh2);
    }

    .settings-section-head {
        padding: 1.2rem 1.5rem;
        border-bottom: 1px solid #f1f5f9;
        background: linear-gradient(135deg, #f8fafc 0%, #f1f5f9 100%);
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .settings-icon {
        width: 45px;
        height: 45px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 1.3rem;
        flex-shrink: 0;
    }

    .icon-info { background: linear-gradient(135deg, #3b82f6, #2563eb); }
    .icon-lock { background: linear-gradient(135deg, #f59e0b, #d97706); }
    .icon-bell { background: linear-gradient(135deg, #10b981, #059669); }

    .settings-section-title {
        font-weight: 700;
        color: var(--navy);
        font-size: 1.05rem;
    }

    .settings-section-body {
        padding: 1.5rem;
    }

    /* INPUT */
    .form-group {
        margin-bottom: 1.2rem;
    }

    .form-group label {
        display: block;
        font-weight: 600;
        color: var(--navy);
        margin-bottom: 0.5rem;
        font-size: 0.9rem;
    }

    .form-control {
        width: 100%;
        padding: 0.8rem 1rem;
        border: 1.5px solid #e2e8f0;
        border-radius: 10px;
        background: #f8fafc;
        font-size: 0.95rem;
        transition: all 0.2s;
        font-family: inherit;
    }

    .form-control:focus {
        outline: none;
        border-color: var(--sky);
        background: var(--white);
        box-shadow: 0 0 0 3px rgba(14,165,233,.1);
    }

    /* GRID */
    .form-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1.2rem;
    }

    .form-row.full {
        grid-template-columns: 1fr;
    }

    /* TOGGLES */
    .toggle-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 1rem 0;
        border-bottom: 1px solid #f1f5f9;
    }

    .toggle-row:last-child {
        border-bottom: none;
    }

    .toggle-label {
        font-weight: 600;
        color: var(--navy);
        font-size: 0.95rem;
    }

    .toggle-sub {
        font-size: 0.85rem;
        color: #64748b;
        margin-top: 0.25rem;
    }

    .form-check-input {
        width: 50px;
        height: 28px;
        cursor: pointer;
    }

    /* BUTTONS */
    .btn-primary {
        background: linear-gradient(135deg, var(--navy), #1e3a5f);
        color: white;
        padding: 0.8rem 1.5rem;
        border: none;
        border-radius: 10px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s;
        margin-top: 0.5rem;
        font-size: 0.95rem;
    }

    .btn-primary:hover {
        background: linear-gradient(135deg, var(--sky), #0284c7);
        transform: translateY(-2px);
        box-shadow: var(--sh2);
    }

    .btn-warning {
        background: linear-gradient(135deg, var(--amber), #d97706);
        color: white;
        padding: 0.8rem 1.5rem;
        border: none;
        border-radius: 10px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s;
        margin-top: 0.5rem;
        font-size: 0.95rem;
    }

    .btn-warning:hover {
        background: linear-gradient(135deg, #d97706, #b45309);
        transform: translateY(-2px);
        box-shadow: var(--sh2);
    }

    /* GRID DEUX COLONNES */
    .settings-grid-2col {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1.5rem;
    }

    /* RESPONSIVE */
    @@media (max-width: 1024px) {
        .settings-page {
            padding: 1.5rem;
        }

        .settings-grid-2col {
            grid-template-columns: 1fr;
        }
    }

    @@media (max-width: 768px) {
        .sidebar-modern {
            width: 200px;
        }

        .dashboard-content-wrapper {
            margin-left: 200px;
            width: calc(100% - 200px);
        }

        .content-area {
            padding: 1.5rem;
        }

        .settings-page {
            padding: 1rem;
        }

        .settings-header h1 {
            font-size: 1.5rem;
        }

        .form-row {
            grid-template-columns: 1fr;
        }

        .settings-grid-2col {
            grid-template-columns: 1fr;
        }
    }

    @@media (max-width: 576px) {
        .sidebar-modern {
            width: 180px;
        }

        .dashboard-content-wrapper {
            margin-left: 180px;
            width: calc(100% - 180px);
        }

        .content-area {
            padding: 1rem;
        }

        .settings-header h1 {
            font-size: 1.3rem;
        }

        .settings-header {
            margin-bottom: 1.5rem;
            padding-bottom: 1rem;
        }

        .btn-primary, .btn-warning {
            padding: 0.7rem 1.2rem;
            font-size: 0.9rem;
        }
    }

    /* RESPONSIVE */
    @@media (max-width: 768px) {
        .form-row {
            grid-template-columns: 1fr;
        }

        .settings-page {
            padding: 1rem;
        }

        .settings-header h1 {
            font-size: 1.5rem;
        }

        .sidebar-modern {
            width: 200px;
        }

        .dashboard-content-wrapper {
            margin-left: 200px;
        }
    }

    @@media (max-width: 576px) {
        .sidebar-modern {
            width: 180px;
        }

        .dashboard-content-wrapper {
            margin-left: 180px;
        }
    }
</style>

<div class="dashboard-container">
    <!-- SIDEBAR -->
    <aside class="sidebar-modern">
        <div class="sidebar-header">
            <h5 class="fw-bold mb-0" style="font-family:'Syne',sans-serif;color:#fff;">👤 PARTICIPANT</h5>
        </div>
        <nav class="sidebar-nav">
            <a href="/Dashboard/Index" class="sidebar-item">
                <i class="bi bi-speedometer2"></i><span>Tableau de Bord</span>
            </a>
            <a href="/Dashboard/MesSeminaires" class="sidebar-item">
                <i class="bi bi-book"></i><span>Mes Séminaires</span>
            </a>
            <a href="/Dashboard/MonProfil" class="sidebar-item">
                <i class="bi bi-person-circle"></i><span>Mon Profil</span>
            </a>
            <a href="/Seminaires/Index" class="sidebar-item">
                <i class="bi bi-search"></i><span>Parcourir</span>
            </a>
            <a href="/Dashboard/Settings" class="sidebar-item active">
                <i class="bi bi-gear-fill"></i><span>Paramètres</span>
            </a>
            <a href="/" class="sidebar-item">
                <i class="bi bi-house"></i><span>Accueil</span>
            </a>
            <a href="/Account/Logout" class="sidebar-item sidebar-item-danger">
                <i class="bi bi-box-arrow-right"></i><span>Déconnexion</span>
            </a>
        </nav>
    </aside>

    <div class="dashboard-content-wrapper">
        <!-- NAVBAR -->
        <nav class="navbar navbar-expand-lg navbar-dark navbar-dashboard sticky-top">
            <div class="container-fluid px-4">
                <a class="navbar-brand" href="/">
                    <img src="/images/logo semina.png" alt="SeminaPro" height="40" class="d-inline-block align-text-top">
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                        data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav ms-auto align-items-center gap-3">
                        <li class="nav-item"><a class="nav-link" href="/"><i class="bi bi-house"></i> Accueil</a></li>
                        <li class="nav-item"><a class="nav-link" href="/Seminaires/Index"><i class="bi bi-book"></i> Séminaires</a></li>
                        <li class="nav-item"><a class="nav-link" href="/About"><i class="bi bi-info-circle"></i> À Propos</a></li>
                        <li class="nav-item"><a class="nav-link" href="/Contact"><i class="bi bi-envelope"></i> Contact</a></li>
                        <li class="nav-item"><a class="nav-link" href="/Dashboard/Index"><i class="bi bi-speedometer2"></i> Mon Tableau</a></li>
                        <li class="nav-item"><span class="nav-text">Connecté: <strong>Participant</strong></span></li>
                        <li class="nav-item">
                            <a href="/Account/Logout" class="btn btn-outline-light btn-sm">
                                <i class="bi bi-box-arrow-right"></i> DÉCONNEXION
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>

        <div class="main-content">
            <div class="content-area">

                <div class="settings-page">

    <!-- HEADER -->
    <div class="settings-header">
        <h1><i class="bi bi-sliders me-2"></i>Paramètres du Compte</h1>
        <p>Gérez votre profil et vos préférences</p>
    </div>

    <!-- ALERTS -->
    @if (!string.IsNullOrEmpty(Model.Message))
    {
        <div class="alert-success">
            <i class="bi bi-check-circle-fill me-2"></i>
            @Model.Message
        </div>
    }

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert-danger">
            <i class="bi bi-exclamation-circle-fill me-2"></i>
            @Model.ErrorMessage
        </div>
    }

    <!-- SECTION: PROFIL -->
    <div class="settings-section">
        <div class="settings-section-head">
            <div class="settings-icon icon-info">
                <i class="bi bi-person"></i>
            </div>
            <div class="settings-section-title">Informations Personnelles</div>
        </div>
        <div class="settings-section-body">
            <form method="post">
                <div class="form-row">
                    <div class="form-group">
                        <label for="Nom">Nom</label>
                        <input type="text" class="form-control" id="Nom" name="Nom" asp-for="Nom" placeholder="Votre nom" />
                    </div>
                    <div class="form-group">
                        <label for="Prenom">Prénom</label>
                        <input type="text" class="form-control" id="Prenom" name="Prenom" asp-for="Prenom" placeholder="Votre prénom" />
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label for="Email">Email</label>
                        <input type="email" class="form-control" id="Email" name="Email" asp-for="Email" placeholder="votre@email.com" />
                    </div>
                    <div class="form-group">
                        <label for="NumeroTelephone">Téléphone</label>
                        <input type="tel" class="form-control" id="NumeroTelephone" name="NumeroTelephone" asp-for="NumeroTelephone" placeholder="+216 XX XXX XXX" />
                    </div>
                </div>
                <button type="submit" class="btn-primary">
                    <i class="bi bi-check-lg me-1"></i>Enregistrer les modifications
                </button>
            </form>
        </div>
    </div>

    <!-- DEUX COLONNES -->
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem;">

        <!-- SECTION: SÉCURITÉ -->
        <div class="settings-section">
            <div class="settings-section-head">
                <div class="settings-icon icon-lock">
                    <i class="bi bi-shield-lock"></i>
                </div>
                <div class="settings-section-title">Sécurité</div>
            </div>
            <div class="settings-section-body">
                <form method="post" asp-page-handler="Security">
                    <div class="form-group">
                        <label for="NewPassword">Nouveau mot de passe</label>
                        <input type="password" class="form-control" id="NewPassword" name="NewPassword" asp-for="NewPassword" placeholder="••••••••" />
                    </div>
                    <div class="form-group">
                        <label for="ConfirmPassword">Confirmer</label>
                        <input type="password" class="form-control" id="ConfirmPassword" name="ConfirmPassword" asp-for="ConfirmPassword" placeholder="••••••••" />
                    </div>
                    <button type="submit" class="btn-warning">
                        <i class="bi bi-lock me-1"></i>Mettre à jour
                    </button>
                </form>
            </div>
        </div>

        <!-- SECTION: PRÉFÉRENCES -->
        <div class="settings-section">
            <div class="settings-section-head">
                <div class="settings-icon icon-bell">
                    <i class="bi bi-bell"></i>
                </div>
                <div class="settings-section-title">Préférences</div>
            </div>
            <!-- DEUX COLONNES -->
            <div class="settings-grid-2col">

                <!-- SECTION: SÉCURITÉ -->
                <div class="settings-section">
                    <div class="settings-section-head">
                        <div class="settings-icon icon-lock">
                            <i class="bi bi-shield-lock"></i>
                        </div>
                        <div class="settings-section-title">Sécurité</div>
                    </div>
                    <div class="settings-section-body">
                        <form method="post" asp-page-handler="Security">
                            <div class="form-group">
                                <label for="NewPassword">Nouveau mot de passe</label>
                                <input type="password" class="form-control" id="NewPassword" name="NewPassword" asp-for="NewPassword" placeholder="••••••••" />
                            </div>
                            <div class="form-group">
                                <label for="ConfirmPassword">Confirmer</label>
                                <input type="password" class="form-control" id="ConfirmPassword" name="ConfirmPassword" asp-for="ConfirmPassword" placeholder="••••••••" />
                            </div>
                            <button type="submit" class="btn-warning">
                                <i class="bi bi-lock me-1"></i>Mettre à jour
                            </button>
                        </form>
                    </div>
                </div>

                <!-- SECTION: PRÉFÉRENCES -->
                <div class="settings-section">
                    <div class="settings-section-head">
                        <div class="settings-icon icon-bell">
                            <i class="bi bi-bell"></i>
                        </div>
                        <div class="settings-section-title">Préférences</div>
                    </div>
                    <div class="settings-section-body">
                        <form method="post" asp-page-handler="Preferences">
                            <div class="toggle-row">
                                <div>
                                    <div class="toggle-label">Notifications par email</div>
                                    <div class="toggle-sub">Recevoir les alertes de séminaires</div>
                                </div>
                                <div class="form-check form-switch mb-0">
                                    <input class="form-check-input" type="checkbox" id="EnableNotifications" 
                                           name="EnableNotifications" asp-for="EnableNotifications" />
                                </div>
                            </div>
                            <button type="submit" class="btn-primary" style="margin-top: 1.5rem;">
                                <i class="bi bi-check-lg me-1"></i>Sauvegarder
                            </button>
                        </form>
                    </div>
                </div>

            </div>

                        </div>
                    </div>
                </div>
            </div>

            <!-- RESPONSIVE GRID FIX -->
            <script>
                document.addEventListener('DOMContentLoaded', function() {
                    if (window.innerWidth <= 768) {
                        const gridElement = document.querySelector('.settings-grid-2col');
                        if (gridElement) {
                            gridElement.style.gridTemplateColumns = '1fr';
                        }
                    }
                });
            </script>

