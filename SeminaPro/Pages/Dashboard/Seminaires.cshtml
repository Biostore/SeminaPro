@page
@model SeminaPro.Pages.Dashboard.SeminairesModel
@{
    ViewData["Title"] = "Séminaires";
    Layout = "_DashboardLayout";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<div class="dashboard-container">
    <!-- NAVBAR -->
    <nav class="navbar navbar-expand-lg navbar-dark navbar-dashboard sticky-top">
        <div class="container-fluid px-4">
            <a class="navbar-brand" href="/">
                <img src="/images/logo semina.png" alt="SeminaPro" height="40" class="d-inline-block align-text-top">
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                    data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto align-items-center gap-3">
                    <li class="nav-item"><a class="nav-link" href="/"><i class="bi bi-house"></i> Accueil</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Seminaires/Index"><i class="bi bi-book"></i> Séminaires</a></li>
                    <li class="nav-item"><a class="nav-link" href="/About"><i class="bi bi-info-circle"></i> À Propos</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Contact"><i class="bi bi-envelope"></i> Contact</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Dashboard/Index"><i class="bi bi-speedometer2"></i> Mon Tableau</a></li>
                    <li class="nav-item"><span class="nav-text">Connecté: <strong>Participant</strong></span></li>
                    <li class="nav-item">
                        <a href="/Account/Logout" class="btn btn-outline-light btn-sm">
                            <i class="bi bi-box-arrow-right"></i> DÉCONNEXION
                        </a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <div class="dashboard-content-wrapper">
        <!-- SIDEBAR FIXED -->
        <aside class="sidebar sidebar-modern">
            <div class="sidebar-header">
                <h5 class="fw-bold mb-0" style="font-family:'Syne',sans-serif;color:#fff;">👤 PARTICIPANT</h5>
            </div>
            <nav class="sidebar-nav">
                <a href="/Dashboard/Index" class="sidebar-item">
                    <i class="bi bi-speedometer2"></i><span>Tableau de Bord</span>
                </a>
                <a href="/Dashboard/MesSeminaires" class="sidebar-item">
                    <i class="bi bi-book"></i><span>Mes Séminaires</span>
                </a>
                <a href="/Dashboard/ProfilParticipant" class="sidebar-item">
                    <i class="bi bi-person-circle"></i><span>Mon Profil</span>
                </a>
                <a href="/Seminaires/Index" class="sidebar-item">
                    <i class="bi bi-search"></i><span>Parcourir</span>
                </a>
                <a href="/Dashboard/Settings" class="sidebar-item">
                    <i class="bi bi-gear-fill"></i><span>Paramètres</span>
                </a>
                <a href="/" class="sidebar-item">
                    <i class="bi bi-house"></i><span>Accueil</span>
                </a>
                <a href="/Account/Logout" class="sidebar-item sidebar-item-danger">
                    <i class="bi bi-box-arrow-right"></i><span>Déconnexion</span>
                </a>
            </nav>
        </aside>

        <!-- MAIN CONTENT -->
        <div class="main-content">
            <div class="content-area">
                <style>
                    :root {
                        --primary: #0f6bff;
                        --success: #22c55e;
                        --warning: #f59e0b;
                        --danger: #ef4444;
                        --dark: #1e293b;
                        --light: #f1f5f9;
                        --muted: #64748b;
                        --gold: #fbbf24;
                        --navy: #0f172a;
                        --sky: #0ea5e9;
                    }

                    .seminaires-page-header {
                        background: linear-gradient(135deg, var(--navy) 0%, #0c2040 50%, #0a3356 100%);
                        border-radius: 16px;
                        padding: 2rem 2.5rem;
                        display: flex;
                        align-items: center;
                        justify-content: space-between;
                        flex-wrap: wrap;
                        gap: 1.5rem;
                        margin-bottom: 2rem;
                        color: white;
                        position: relative;
                        overflow: hidden;
                        box-shadow: 0 20px 50px rgba(15, 23, 42, 0.16);
                    }

                    .seminaires-page-header::before {
                        content: '';
                        position: absolute;
                        inset: 0;
                        background: radial-gradient(ellipse at 78% 50%, rgba(14, 165, 233, 0.2) 0%, transparent 60%);
                        pointer-events: none;
                    }

                    .seminaires-header-content {
                        position: relative;
                        z-index: 1;
                    }

                    .seminaires-header-content h1 {
                        font-family: 'Syne', sans-serif;
                        font-size: 2rem;
                        font-weight: 800;
                        margin: 0 0 0.5rem 0;
                        letter-spacing: -0.02em;
                    }

                    .seminaires-header-content p {
                        color: #94a3b8;
                        margin: 0;
                        font-size: 0.9rem;
                    }

                    .seminaires-filters {
                        display: flex;
                        gap: 1rem;
                        flex-wrap: wrap;
                        margin-bottom: 2rem;
                    }

                    .filter-btn {
                        padding: 0.6rem 1.2rem;
                        border: 1px solid #e2e8f0;
                        background: white;
                        border-radius: 8px;
                        cursor: pointer;
                        font-weight: 500;
                        font-size: 0.9rem;
                        transition: all 0.2s;
                    }

                    .filter-btn:hover {
                        background: var(--light);
                        border-color: var(--primary);
                    }

                    .filter-btn.active {
                        background: var(--primary);
                        color: white;
                        border-color: var(--primary);
                    }

                    .seminaires-grid {
                        display: grid;
                        grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
                        gap: 1.5rem;
                        margin-bottom: 2rem;
                    }

                    .seminaire-full-card {
                        background: white;
                        border-radius: 12px;
                        border: 1px solid #e2e8f0;
                        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
                        overflow: hidden;
                        transition: all 0.3s ease;
                        display: flex;
                        flex-direction: column;
                    }

                    .seminaire-full-card:hover {
                        box-shadow: 0 8px 16px rgba(0, 0, 0, 0.1);
                        border-color: var(--primary);
                        transform: translateY(-4px);
                    }

                    .seminaire-full-image {
                        width: 100%;
                        height: 200px;
                        object-fit: cover;
                    }

                    .seminaire-full-content {
                        padding: 1.5rem;
                        flex: 1;
                        display: flex;
                        flex-direction: column;
                    }

                    .seminaire-full-title {
                        font-size: 1.1rem;
                        font-weight: 700;
                        color: var(--dark);
                        margin: 0 0 0.5rem 0;
                    }

                    .seminaire-full-code {
                        color: var(--muted);
                        font-size: 0.85rem;
                        margin-bottom: 1rem;
                    }

                    .seminaire-full-info {
                        display: flex;
                        flex-direction: column;
                        gap: 0.75rem;
                        margin-bottom: 1rem;
                        flex: 1;
                    }

                    .info-row {
                        display: flex;
                        align-items: center;
                        gap: 0.5rem;
                        font-size: 0.9rem;
                    }

                    .info-row i {
                        color: var(--primary);
                        width: 20px;
                        text-align: center;
                    }

                    .info-row strong {
                        font-weight: 600;
                        color: var(--dark);
                        min-width: 70px;
                    }

                    .info-row span {
                        color: var(--muted);
                    }

                    .seminaire-full-footer {
                        display: flex;
                        justify-content: space-between;
                        align-items: center;
                        padding-top: 1rem;
                        border-top: 1px solid #e2e8f0;
                    }

                    .seminaire-full-price {
                        font-size: 1.3rem;
                        font-weight: 800;
                        color: var(--primary);
                    }

                    .seminaire-actions {
                        display: flex;
                        gap: 0.5rem;
                    }

                    .btn-icon {
                        padding: 0.5rem 1rem;
                        border: 1px solid #e2e8f0;
                        background: white;
                        border-radius: 8px;
                        cursor: pointer;
                        font-size: 0.9rem;
                        transition: all 0.2s;
                        display: inline-flex;
                        align-items: center;
                        gap: 0.4rem;
                    }

                    .btn-icon:hover {
                        background: var(--light);
                        border-color: var(--primary);
                        color: var(--primary);
                    }

                    .btn-icon.btn-primary {
                        background: var(--primary);
                        color: white;
                        border-color: var(--primary);
                    }

                    .btn-icon.btn-primary:hover {
                        background: #0d5ae8;
                        border-color: #0d5ae8;
                    }

                    .empty-state-page {
                        text-align: center;
                        padding: 4rem 2rem;
                        background: white;
                        border-radius: 12px;
                        border: 1px solid #e2e8f0;
                    }

                    .empty-state-icon {
                        font-size: 3rem;
                        color: var(--muted);
                        margin-bottom: 1rem;
                    }

                    .empty-state-title {
                        font-size: 1.3rem;
                        font-weight: 700;
                        color: var(--dark);
                        margin: 0;
                    }

                    .empty-state-text {
                        color: var(--muted);
                        margin: 0.5rem 0 1.5rem 0;
                    }

                    .badge-status {
                        display: inline-flex;
                        align-items: center;
                        gap: 0.4rem;
                        padding: 0.3rem 0.6rem;
                        border-radius: 6px;
                        font-size: 0.75rem;
                        font-weight: 600;
                    }

                    .badge-available {
                        background: rgba(34, 197, 94, 0.1);
                        color: var(--success);
                    }

                    .badge-full {
                        background: rgba(239, 68, 68, 0.1);
                        color: var(--danger);
                    }
                </style>

                <style>
                    @@media (max-width: 768px) {
                        .seminaires-grid {
                            grid-template-columns: 1fr;
                        }

                        .seminaires-page-header {
                            padding: 1.5rem;
                        }

                        .seminaires-header-content h1 {
                            font-size: 1.5rem;
                        }
                    }
                </style>

                <!-- HEADER -->
                <div class="seminaires-page-header">
                    <div class="seminaires-header-content">
                        <h1><i class="bi bi-calendar-event"></i> Séminaires Disponibles</h1>
                        <p>Découvrez et inscrivez-vous aux séminaires à venir</p>
                    </div>
                </div>

                <!-- FILTERS -->
                <div class="seminaires-filters">
                    <button class="filter-btn active" data-filter="all">
                        <i class="bi bi-funnel"></i> Tous
                    </button>
                    <button class="filter-btn" data-filter="upcoming">
                        <i class="bi bi-calendar-check"></i> À Venir
                    </button>
                    <button class="filter-btn" data-filter="available">
                        <i class="bi bi-check-circle"></i> Disponibles
                    </button>
                </div>

                <!-- SEMINAIRES GRID -->
                @if (Model.Seminaires.Any())
                {
                    <div class="seminaires-grid">
                        @foreach (var seminaire in Model.Seminaires)
                        {
                            var isInscribed = Model.Inscriptions.Any(i => i.SeminaireId == seminaire.Id);
                            var isAvailable = seminaire.Inscriptions.Count < seminaire.NombreMaximal;

                            <div class="seminaire-full-card" data-status="@(isAvailable ? "available" : "full")">
                                <img src="@(seminaire.ImageUrl ?? "/images/default-seminaire.png")" 
                                     alt="@seminaire.Titre" class="seminaire-full-image" />
                                <div class="seminaire-full-content">
                                    <h3 class="seminaire-full-title">@seminaire.Titre</h3>
                                    <p class="seminaire-full-code">
                                        <i class="bi bi-hash"></i> @seminaire.Code
                                    </p>

                                    <div class="seminaire-full-info">
                                        <div class="info-row">
                                            <i class="bi bi-calendar"></i>
                                            <strong>Date:</strong>
                                            <span>@seminaire.DateSeminaire.ToString("dd MMMM yyyy")</span>
                                        </div>
                                        <div class="info-row">
                                            <i class="bi bi-geo-alt"></i>
                                            <strong>Lieu:</strong>
                                            <span>@seminaire.Lieu</span>
                                        </div>
                                        <div class="info-row">
                                            <i class="bi bi-people"></i>
                                            <strong>Places:</strong>
                                            <span>@seminaire.Inscriptions.Count / @seminaire.NombreMaximal</span>
                                        </div>
                                    </div>

                                    @if (isAvailable)
                                    {
                                        <div class="badge-status badge-available">
                                            <i class="bi bi-check-circle"></i> Places Disponibles
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="badge-status badge-full">
                                            <i class="bi bi-x-circle"></i> Complet
                                        </div>
                                    }
                                </div>

                                <div class="seminaire-full-footer">
                                    <div class="seminaire-full-price">@seminaire.Tarif.ToString("N2") DH</div>
                                    <div class="seminaire-actions">
                                        <a href="/Seminaires/Inscription?seminaireId=@seminaire.Id" class="btn-icon btn-primary">
                                            <i class="bi bi-eye"></i> Détails
                                        </a>
                                        @if (isInscribed)
                                        {
                                            <button type="button" class="btn-icon" onclick="alert('Vous êtes déjà inscrit à ce séminaire')" disabled>
                                                <i class="bi bi-check"></i> Inscrit
                                            </button>
                                        }
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="empty-state-page">
                        <div class="empty-state-icon">
                            <i class="bi bi-inbox"></i>
                        </div>
                        <h3 class="empty-state-title">Aucun Séminaire Disponible</h3>
                        <p class="empty-state-text">Aucun séminaire ne correspond à vos critères de recherche</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script>
    document.querySelectorAll('.filter-btn').forEach(btn => {
        btn.addEventListener('click', function () {
            document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
            this.classList.add('active');

            const filter = this.dataset.filter;
            document.querySelectorAll('.seminaire-full-card').forEach(card => {
                if (filter === 'all') {
                    card.style.display = 'flex';
                } else if (filter === 'available') {
                    card.style.display = card.dataset.status === 'available' ? 'flex' : 'none';
                } else if (filter === 'upcoming') {
                    card.style.display = 'flex';
                }
            });
        });
    });
</script>
